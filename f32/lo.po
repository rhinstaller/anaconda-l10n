"\n"
"%s"

#: pyanaconda/storage/utils.py:408
#, python-format
msgid ""
"The following error was encountered while downloading the escrow "
"certificate:\n"
"\n"
"%s"
msgstr ""
"ພົບຂໍ້ຜິດພາດຕໍ່ໄປນີ້ໃນຂະນະທີ່ດາວໂຫຼດໃບຢັ້ງຢືນ Escrow:\n"
"\n"
"%s"

#: pyanaconda/storage/utils.py:495
#, python-format
msgid ""
"You selected disk %(selected)s, which contains devices that also use "
"unselected disk %(unselected)s. You must select or de-select these disks as "
"a set."
msgid_plural ""
"You selected disk %(selected)s, which contains devices that also use "
"unselected disks %(unselected)s. You must select or de-select these disks as "
"a set."
msgstr[0] ""
"ທ່ານເລືອກດິສກ໌ %(selected)s ເຊິ່ງມີອຸປະກອນທີ່ນຳໃຊ້ດິສກ໌ %(unselected)s ທີ່ບໍ່ໄດ້ເລືອກນຳ. ທ່ານຕ້ອງເ"
"ລືອກ ຫຼື ຍົກເລີກການເລືອກດິສກ໌ເຫຼົ່ານີ້ເປັນຊຸດ."

#: pyanaconda/storage/checker.py:51
#, python-format
msgid ""
"Your root partition is less than %(size)s which is usually too small to "
"install %(product)s."
msgstr ""
"ພາຕິຊັນຮາກ (root) ຂອງທ່ານນ້ອຍກວ່າ %(size)s ເຊິ່ງໂດຍປົກກະຕິແລ້ວນ້ອຍເກີນໄປທີ່ຈະຕິດຕັ້ງ %"
"(product)s."

#: pyanaconda/storage/checker.py:57
#, python-format
msgid ""
"You have not defined a root partition (/), which is required for "
"installation of %s to continue."
msgstr ""
"ທ່ານຍັງບໍ່ໄດ້ກຳນົດພາຕິຊັນຮາກ (root) (/), ເຊິ່ງຈຳເປັນສຳລັບການຕິດຕັ້ງ %s ເພື່ອດຳເນີນການຕໍ່."

#: pyanaconda/storage/checker.py:62
#: pyanaconda/modules/storage/partitioning/interactive/utils.py:437
msgid "You must create a new file system on the root device."
msgstr "ທ່ານຕ້ອງສ້າງລະບົບໄຟລ໌ໃໝ່ເທິງອຸປະກອນຮາກ (root)."

#: pyanaconda/storage/checker.py:88
msgid ""
"This platform requires /boot on a dedicated partition or logical volume. If "
"you do not want a /boot volume, you must place / on a dedicated non-LVM "
"partition."
msgstr ""
"ແພລັດຟອມນີ້ຕ້ອງການ /boot ຢູ່ໃນພາຕິຊັນສະເພາະ ຫຼື logical volume. ຖ້າທ່ານບໍ່ຕ້ອງການ /boot "
"volume, ທ່ານຕ້ອງວາງ / ໄວ້ໃນພາຕິຊັນສະເພາະທີ່ບໍ່ແມ່ນ LVM."

#: pyanaconda/storage/checker.py:95
#, python-brace-format
msgid ""
"The LDL DASD disk {name} ({busid}) cannot be used for the installation. "
"Please format it."
msgstr ""
"ດິສກ໌ LDL DASD {name} ({busid}) ບໍ່ສາມາດໃຊ້ສຳລັບການຕິດຕັ້ງໄດ້. ກະລຸນາຟໍແມັດມັນກ່ອນ."

#: pyanaconda/storage/checker.py:117
#, python-format
msgid ""
"It is recommended to create a new file system on your %(mount)s partition."
msgstr "ຂໍແນະນຳໃຫ້ສ້າງລະບົບໄຟລ໌ໃໝ່ໃນພາຕິຊັນ %(mount)s ຂອງທ່ານ."

#: pyanaconda/storage/checker.py:133
#, python-format
msgid ""
"Your %(mount)s partition is less than %(size)s which is lower than "
"recommended for a normal %(productName)s install."
msgstr ""
"ພາຕິຊັນ %(mount)s ຂອງທ່ານນ້ອຍກວ່າ %(size)s ເຊິ່ງຕ່ຳກວ່າຂະໜາດທີ່ແນະນຳສຳລັບການຕິດຕັ້ງ %"
"(productName)s ປົກກະຕິ."

#: pyanaconda/storage/checker.py:155
#, python-format
msgid ""
"Your %(mount)s partition is too small for %(format)s formatting (allowable "
"size is %(minSize)s to %(maxSize)s)"
msgstr ""
"ພາຕິຊັນ %(mount)s ຂອງທ່ານນ້ອຍເກີນໄປສຳລັບການຟໍແມັດ %(format)s (ຂະໜາດທີ່ອະນຸຍາດແມ່ນ %"
"(minSize)s ຫາ %(maxSize)s)"

#: pyanaconda/storage/checker.py:161
#, python-format
msgid ""
"Your %(mount)s partition is too large for %(format)s formatting (allowable "
"size is %(minSize)s to %(maxSize)s)"
msgstr ""
"ພາຕິຊັນ %(mount)s ຂອງທ່ານໃຫຍ່ເກີນໄປສຳລັບການຟໍແມັດ %(format)s (ຂະໜາດທີ່ອະນຸຍາດແມ່ນ %"
"(minSize)s ຫາ %(maxSize)s)"

#: pyanaconda/storage/checker.py:179
msgid "No valid boot loader target device found. See below for details."
msgstr "ບໍ່ພົບອຸປະກອນເປົ້າໝາຍສຳລັບຕົວໂຫຼດບູດທີ່ຖືກຕ້ອງ. ເບິ່ງລາຍລະອຽດດ້ານລຸ່ມ."

#: pyanaconda/storage/checker.py:194
msgid "You have not created a bootable partition."
msgstr "ທ່ານຍັງບໍ່ໄດ້ສ້າງພາຕິຊັນທີ່ສາມາດບູດໄດ້."

#: pyanaconda/storage/checker.py:229
msgid ""
"Your BIOS-based system needs a special partition to boot from a GPT disk "
"label. To continue, please create a 1MiB 'biosboot' type partition."
msgstr ""
"ລະບົບທີ່ອີງໃສ່ BIOS ຂອງທ່ານຕ້ອງການພາຕິຊັນພິເສດເພື່ອບູດຈາກປ້າຍຊື່ດິສກ໌ GPT. ເພື່ອດຳເນີນການຕໍ່, ກະລຸນາສ້"
"າງພາຕິຊັນປະເພດ 'biosboot' ຂະໜາດ 1MiB."

#: pyanaconda/storage/checker.py:251
#, python-format
msgid ""
"You have not specified a swap partition. %(requiredMem)s of memory is "
"recommended to continue installation without a swap partition, but you only "
"have %(installedMem)s."
msgstr ""
"ທ່ານຍັງບໍ່ໄດ້ລະບຸພາຕິຊັນ swap. ແນະນຳໃຫ້ມີໜ່ວຍຄວາມຈຳ %(requiredMem)s ເພື່ອສືບຕໍ່ການຕິດຕັ້ງໂດຍບໍ່ມີພາ"
"ຕິຊັນ swap, ແຕ່ທ່ານມີພຽງແຕ່ %(installedMem)s."

#: pyanaconda/storage/checker.py:258
#, python-format
msgid ""
"You have not specified a swap partition. %(requiredMem)s of memory is "
"required to continue installation without a swap partition, but you only "
"have %(installedMem)s."
msgstr ""
"ທ່ານຍັງບໍ່ໄດ້ລະບຸພາຕິຊັນ swap. ຈຳເປັນຕ້ອງມີໜ່ວຍຄວາມຈຳ %(requiredMem)s ເພື່ອສືບຕໍ່ການຕິດຕັ້ງໂດຍບໍ່ມີພ"
"າຕິຊັນ swap, ແຕ່ທ່ານມີພຽງແຕ່ %(installedMem)s."

#: pyanaconda/storage/checker.py:264
msgid ""
"You have not specified a swap partition. Although not strictly required in "
"all cases, it will significantly improve performance for most installations."
msgstr ""
"ທ່ານຍັງບໍ່ໄດ້ລະບຸພາຕິຊັນ swap. ເຖິງແມ່ນວ່າມັນຈະບໍ່ໄດ້ບັງຄັບໃນທຸກກໍລະນີ, ແຕ່ມັນຈະປັບປຸງປະສິດທິພາບຢ່າງຫຼວງຫຼ"
"າຍສຳລັບການຕິດຕັ້ງສ່ວນໃຫຍ່."

#: pyanaconda/storage/checker.py:282
msgid ""
"At least one of your swap devices does not have a UUID, which is common in "
"swap space created using older versions of mkswap. These devices will be "
"referred to by device path in /etc/fstab, which is not ideal since device "
"paths can change under a variety of circumstances. "
msgstr ""
"ຢ່າງໜ້ອຍໜຶ່ງໃນອຸປະກອນ swap ຂອງທ່ານແມ່ນບໍ່ມີ UUID, ເຊິ່ງເປັນເລື່ອງປົກກະຕິສຳລັບພື້ນທີ່ swap ທີ່ສ້າງຂຶ້ນມາໂ"
"ດຍໃຊ້ mkswap ລຸ້ນເກົ່າ. ອຸປະກອນເຫຼົ່ານີ້ຈະຖືກອ້າງອີງໂດຍເສັ້ນທາງອຸປະກອນ (device path) ໃນ /etc/"
"fstab, ເຊິ່ງບໍ່ເໝາະສົມປານໃດ ເພາະເສັ້ນທາງອຸປະກອນສາມາດປ່ຽນແປງໄດ້ໃນຫຼາຍສະຖານະການ. "

#: pyanaconda/storage/checker.py:301
#, python-format
msgid ""
"This mount point is invalid. The %s directory must be on the / file system."
msgstr "ຈຸດເຊື່ອມຕໍ່ນີ້ບໍ່ຖືກຕ້ອງ. ໄດເຣັກທໍຣີ %s ຕ້ອງຢູ່ເທິງ/ລະບົບໄຟລ໌."

#: pyanaconda/storage/checker.py:318
#, python-format
msgid "The mount point %s must be on a linux file system."
msgstr "ຈຸດເຊື່ອມຕໍ່ %s ຕ້ອງຢູ່ເທິງລະບົບໄຟລ໌ Linux."

#: pyanaconda/storage/checker.py:342
msgid ""
"The existing unlocked LUKS device {} cannot be used for the installation "
"without an encryption key specified for this device. Please, rescan the "
"storage."
msgstr ""
"ອຸປະກອນ LUKS {} ທີ່ປົດລັອກຢູ່ແລ້ວ ບໍ່ສາມາດນຳໃຊ້ໃນການຕິດຕັ້ງໄດ້ ໂດຍທີ່ບໍ່ມີການລະບຸລະຫັດການເຂົ້າລະຫັດສຳລັ"
"ບອຸປະກອນນີ້. ກະລຸນາສະແກນບ່ອນເກັບຂໍ້ມູນຄືນໃໝ່."

#: pyanaconda/storage/checker.py:363
#, python-format
msgid ""
"Encryption requested for LUKS device %s but no encryption key specified for "
"this device."
msgstr ""
"ມີການຮ້ອງຂໍການເຂົ້າລະຫັດສຳລັບອຸປະກອນ LUKS %s ແຕ່ບໍ່ມີການລະບຸລະຫັດການເຂົ້າລະຫັດສຳລັບອຸປະກອນນີ້."

#: pyanaconda/storage/checker.py:385
#, python-format
msgid ""
"The available memory is less than %(size)s which can be too small for LUKS2 "
"format. It may fail."
msgstr ""
"ໜ່ວຍຄວາມຈຳທີ່ມີຢູ່ແມ່ນໜ້ອຍກວ່າ %(size)s ເຊິ່ງອາດຈະໜ້ອຍເກີນໄປສຳລັບຮູບແບບ LUKS2. ມັນອາດຈະຫຼົ້ມເຫຼວ."

#: pyanaconda/storage/checker.py:412
#, python-format
msgid ""
"%s is currently mounted and cannot be used for the installation. Please "
"unmount it and retry."
msgstr ""
"%s ຖືກເຊື່ອມຕໍ່ (mounted) ຢູ່ ແລະ ບໍ່ສາມາດນຳໃຊ້ໃນການຕິດຕັ້ງໄດ້. ກະລຸນາຍົກເລີກການເຊື່ອມຕໍ່ "
"(unmount) ແລ້ວລອງໃໝ່."

#: pyanaconda/storage/checker.py:447
msgid ""
"Selected disks {} contain volume group '{}' that also uses further "
"unselected disks. You must select or de-select all these disks as a set."
msgstr ""
"ດິສທີ່ເລືອກ {} ປະກອບມີກຸ່ມວໍລຸມ (volume group) '{}' ທີ່ໃຊ້ດິສອື່ນໆທີ່ບໍ່ໄດ້ຖືກເລືອກນຳ. ທ່ານຕ້ອງເລືອກ "
"ຫຼື ຍົກເລີກການເລືອກດິສເຫຼົ່ານີ້ທັງໝົດເປັນຊຸດ."

#: pyanaconda/startup_utils.py:79
#, python-format
msgid ""
"%(product_name)s requires %(needed_ram)s MB of memory to install, but you "
"only have %(total_ram)s MB on this machine.\n"
msgstr ""
"%(product_name)s ຕ້ອງການ %(needed_ram)s MB ເພື່ອຕິດຕັ້ງ, ແຕ່ທ່ານມີພຽງແຕ່ %(total_ram)s "
"MB ໃນເຄື່ອງນີ້.\n"

#: pyanaconda/startup_utils.py:81
#, python-format
msgid ""
"The %(product_name)s graphical installer requires %(needed_ram)s MB of "
"memory, but you only have %(total_ram)s MB\n"
"."
msgstr ""
"ຕົວຕິດຕັ້ງແບບກຣາຟິກຂອງ %(product_name)s ຕ້ອງການ %(needed_ram)s MB, ແຕ່ທ່ານມີພຽງແຕ່ %"
"(total_ram)s MB\n"
"."

#: pyanaconda/startup_utils.py:84
msgid ""
"\n"
"Press [Enter] to reboot your system.\n"
msgstr ""
"\n"
"ກົດ [Enter] ເພື່ອເລີ່ມລະບົບໃໝ່.\n"

#: pyanaconda/startup_utils.py:86
msgid "Not enough RAM"
msgstr "RAM ບໍ່ພຽງພໍ"

#: pyanaconda/startup_utils.py:87
msgid ""
" Try the text mode installer by running:\n"
"\n"
"'/usr/bin/liveinst -T'\n"
"\n"
" from a root terminal."
msgstr ""
" ລອງໃຊ້ຕົວຕິດຕັ້ງແບບຂໍ້ຄວາມ (text mode) ໂດຍການຣັນ:\n"
"\n"
"'/usr/bin/liveinst -T'\n"
"\n"
" ຈາກເທີມິນໍຣາກ (root terminal)."

#: pyanaconda/startup_utils.py:89
msgid " Starting text mode."
msgstr " ກຳລັງເລີ່ມໂໝດຂໍ້ຄວາມ."

#: pyanaconda/startup_utils.py:126
msgid "The installation cannot continue and the system will be rebooted"
msgstr "ການຕິດຕັ້ງບໍ່ສາມາດດຳເນີນການຕໍ່ໄດ້ ແລະ ລະບົບຈະຖືກເລີ່ມໃໝ່"

#: pyanaconda/startup_utils.py:127
msgid "Press ENTER to continue"
msgstr "ກົດ ENTER ເພື່ອດຳເນີນການຕໍ່"

#: pyanaconda/startup_utils.py:224
#, python-format
msgid "Please ssh install@%s to begin the install."
msgstr "ກະລຸນາ ssh install@%s ເພື່ອເລີ່ມການຕິດຕັ້ງ."

#: pyanaconda/startup_utils.py:226
msgid "Please ssh install@HOSTNAME to continue installation."
msgstr "ກະລຸນາ ssh install@HOSTNAME ເພື່ອຕິດຕັ້ງຕໍ່."

#: pyanaconda/payload/manager.py:75
msgid "Failed to set up installation source"
msgstr "ຕັ້ງຄ່າແຫຼ່ງຕິດຕັ້ງບໍ່ສຳເລັດ"

#: pyanaconda/payload/manager.py:76
msgid "Error downloading package metadata"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການດາວໂຫຼດເມຕາດາຕາຂອງແພັກເກດ"

#: pyanaconda/payload/flatpak.py:205
#, python-format
msgid "Installing %(flatpak_name)s"
msgstr "ກຳລັງຕິດຕັ້ງ %(flatpak_name)s"

#: pyanaconda/payload/rpmostreepayload.py:127
#, python-format
msgid "Receiving objects: %(percent)d%% (%(fetched)d/%(requested)d) %(bytes)s"
msgstr "ກຳລັງຮັບອັອບເຈັກ: %(percent)d%% (%(fetched)d/%(requested)d) %(bytes)s"

#: pyanaconda/payload/rpmostreepayload.py:133
msgid "Writing objects"
msgstr "ກຳລັງຂຽນອັອບເຈັກ"

#: pyanaconda/payload/rpmostreepayload.py:232
#, python-format
msgid "Starting pull of %(branchName)s from %(source)s"
msgstr "ກຳລັງເລີ່ມດຶງຂໍ້ມູນ %(branchName)s ຈາກ %(source)s"

#: pyanaconda/payload/rpmostreepayload.py:262
#, python-format
msgid "Preparing deployment of %s"
msgstr "ກຳລັງກຽມການວາງລະບົບ (deployment) ຂອງ %s"

#: pyanaconda/payload/rpmostreepayload.py:282
#, python-format
msgid "Deployment starting: %s"
msgstr "ເລີ່ມການວາງລະບົບ: %s"

#: pyanaconda/payload/rpmostreepayload.py:285
#, python-format
msgid "Deployment complete: %s"
msgstr "ວາງລະບົບສຳເລັດ: %s"

#: pyanaconda/payload/rpmostreepayload.py:504
msgid "Starting Flatpak installation"
msgstr "ກຳລັງເລີ່ມການຕິດຕັ້ງ Flatpak"

#: pyanaconda/payload/rpmostreepayload.py:521
msgid "Post-installation flatpak tasks"
msgstr "ວຽກຫຼັງການຕິດຕັ້ງ Flatpak"

#: pyanaconda/payload/rpmostreepayload.py:527
msgid "Flatpak installation has finished"
msgstr "ການຕິດຕັ້ງ Flatpak ສິ້ນສຸດແລ້ວ"

#: pyanaconda/payload/dnfpayload.py:246
#, python-format
msgid ""
"Downloading %(total_files)s RPMs, %(downloaded)s / %(total_size)s "
"(%(percent)d%%) done."
msgstr ""
