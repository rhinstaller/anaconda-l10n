#: pyanaconda/bootloader/grub2.py:526
#, python-format
msgid ""
"boot loader stage2 device %(stage2dev)s is on a multi-disk array, but boot "
"loader stage1 device %(stage1dev)s is not. A drive failure in %(stage2dev)s "
"could render the system unbootable."
msgstr ""
"ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 2 %(stage2dev)s ຢູ່ໃນອາເຣແບບຫຼາຍດິສກ໌, ແຕ່ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 1 %"
"(stage1dev)s ບໍ່ໄດ້ຢູ່. ຖ້າດິສກ໌ໃນ %(stage2dev)s ເພພັງອາດຈະເຮັດໃຫ້ລະບົບບໍ່ສາມາດບູດໄດ້."

#: pyanaconda/bootloader/grub2.py:533
#, python-format
msgid ""
"boot loader stage2 device %(stage2dev)s is on a multi-disk array, but boot "
"loader stage1 device %(stage1dev)s is not part of this array. The stage1 "
"boot loader will only be installed to a single drive."
msgstr ""
"ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 2 %(stage2dev)s ຢູ່ໃນອາເຣແບບຫຼາຍດິສກ໌, ແຕ່ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 1 %"
"(stage1dev)s ບໍ່ໄດ້ເປັນສ່ວນໜຶ່ງຂອງອາເຣນີ້. ຕົວໂຫຼດບູດລະດັບ 1 ຈະຖືກຕິດຕັ້ງໃສ່ດິສກ໌ດຽວເທົ່ານັ້ນ."

#: pyanaconda/bootloader/base.py:149
msgid "/boot file system"
msgstr "ລະບົບໄຟລ໌ /boot"

#: pyanaconda/bootloader/base.py:298
#, python-format
msgid ""
"RAID sets that contain '%(desc)s' must have one of the following raid "
"levels: %(raid_level)s."
msgstr ""
"ຊຸດ RAID ທີ່ມີ '%(desc)s' ຕ້ອງມີໜຶ່ງໃນລະດັບ RAID ຕໍ່ໄປນີ້: %(raid_level)s."

#: pyanaconda/bootloader/base.py:306
#, python-format
msgid ""
"RAID sets that contain '%(desc)s' must have one of the following metadata "
"versions: %(metadata_versions)s."
msgstr ""
"ຊຸດ RAID ທີ່ມີ '%(desc)s' ຕ້ອງມີໜຶ່ງໃນເວີຊັນ metadata ຕໍ່ໄປນີ້: %(metadata_versions)s."

#: pyanaconda/bootloader/base.py:314
#, python-format
msgid ""
"RAID sets that contain '%(desc)s' must have one of the following device "
"types: %(types)s."
msgstr "ຊຸດ RAID ທີ່ມີ '%(desc)s' ຕ້ອງມີໜຶ່ງໃນປະເພດອຸປະກອນຕໍ່ໄປນີ້: %(types)s."

#: pyanaconda/bootloader/base.py:330
#, python-format
msgid "%(name)s must have one of the following disklabel types: %(types)s."
msgstr "%(name)s ຕ້ອງມີໜຶ່ງໃນປະເພດປ້າຍຊື່ດິສກ໌ (disklabel) ຕໍ່ໄປນີ້: %(types)s."

#: pyanaconda/bootloader/base.py:342
#, python-format
msgid "%(desc)s cannot be of type %(type)s."
msgstr "%(desc)s ບໍ່ສາມາດເປັນປະເພດ %(type)s ໄດ້."

#: pyanaconda/bootloader/base.py:348
#, python-format
msgid "%(desc)s must be mounted on one of %(mountpoints)s."
msgstr "%(desc)s ຕ້ອງເຊື່ອມຕໍ່ກັບໜຶ່ງໃນ %(mountpoints)s."

#: pyanaconda/bootloader/base.py:360
#, python-format
msgid "%(desc)s must be between %(min)d and %(max)d MB in size"
msgstr "%(desc)s ຕ້ອງມີຂະໜາດລະຫວ່າງ %(min)d ຫາ %(max)d MB"

#: pyanaconda/bootloader/base.py:366
#, python-format
msgid "%(desc)s must not be smaller than %(min)dMB."
msgstr "%(desc)s ຕ້ອງບໍ່ນ້ອຍກວ່າ %(min)dMB."

#: pyanaconda/bootloader/base.py:375
#, python-format
msgid "%(desc)s must not be larger than %(max)dMB."
msgstr "%(desc)s ຕ້ອງບໍ່ໃຫຍ່ກວ່າ %(max)dMB."

#: pyanaconda/bootloader/base.py:393
#, python-format
msgid "%(desc)s must be within the first %(max_end)s of the disk."
msgstr "%(desc)s ຕ້ອງຢູ່ພາຍໃນ %(max_end)s ທຳອິດຂອງດິສກ໌."

#: pyanaconda/bootloader/base.py:403
#, python-format
msgid "%s must be on a primary partition."
msgstr "%s ຕ້ອງຢູ່ໃນພາຕິຊັນຫຼັກ."

#: pyanaconda/bootloader/base.py:488
msgid ""
"Boot loader stage1 device cannot be on an iSCSI disk which is not configured "
"in iBFT."
msgstr ""
"ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 1 ບໍ່ສາມາດຢູ່ໃນດິສກ໌ iSCSI ທີ່ບໍ່ໄດ້ຕັ້ງຄ່າໃນ iBFT."

#: pyanaconda/bootloader/base.py:545 pyanaconda/bootloader/base.py:659
#, python-format
msgid "%s cannot be on an encrypted block device."
msgstr "%s ບໍ່ສາມາດຢູ່ໃນອຸປະກອນບລັອກທີ່ເຂົ້າລະຫັດໄດ້."

#: pyanaconda/bootloader/base.py:611
#, python-format
msgid ""
"%(bootloader_stage2_description)s cannot be on an iSCSI disk which is not "
"configured in iBFT."
msgstr ""
"%(bootloader_stage2_description)s ບໍ່ສາມາດຢູ່ໃນດິສກ໌ iSCSI ທີ່ບໍ່ໄດ້ຕັ້ງຄ່າໃນ iBFT."

#: pyanaconda/bootloader/base.py:618
#, python-format
msgid "%(desc)s cannot be of type %(type)s"
msgstr "%(desc)s ບໍ່ສາມາດເປັນປະເພດ %(type)s"

#: pyanaconda/bootloader/execution.py:175
msgid "No match found for given boot drive \"{}\"."
msgstr "ບໍ່ພົບຂໍ້ມູນທີ່ກົງກັນສຳລັບໄດຣຟ໌ບູດ \"{}\" ທີ່ໃຫ້ມາ."

#: pyanaconda/bootloader/execution.py:179
msgid "More than one match found for given boot drive \"{}\"."
msgstr "ພົບຂໍ້ມູນທີ່ກົງກັນຫຼາຍກວ່າໜຶ່ງອັນສຳລັບໄດຣຟ໌ບູດ \"{}\" ທີ່ໃຫ້ມາ."

#: pyanaconda/bootloader/execution.py:183
msgid "Requested boot drive \"{}\" doesn't exist or cannot be used."
msgstr "ໄດຣຟ໌ບູດ \"{}\" ທີ່ຮ້ອງຂໍບໍ່ມີຢູ່ ຫຼື ບໍ່ສາມາດໃຊ້ງານໄດ້."

#: pyanaconda/input_checking.py:539
msgid "Full name cannot contain colon characters"
msgstr "ຊື່ເຕັມບໍ່ສາມາດມີຕົວອັກສອນຈ້ຳສອງເມັດ (colon)"

#: pyanaconda/network.py:110
msgid "Host name cannot be None or an empty string."
msgstr "ຊື່ໂຮສຕ໌ບໍ່ສາມາດເປັນຄ່າຫວ່າງ (None) ຫຼື ເປັນຊ່ອງຫວ່າງ."

#: pyanaconda/network.py:113
msgid "Host name must be 255 or fewer characters in length."
msgstr "ຊື່ໂຮສຕ໌ຕ້ອງມີຄວາມຍາວ 255 ຕົວອັກສອນ ຫຼື ໜ້ອຍກວ່າ."

#: pyanaconda/network.py:116
msgid "Local host name must not end with period '.'."
msgstr "ຊື່ໂຮສຕ໌ພາຍໃນຕ້ອງບໍ່ລົງທ້າຍດ້ວຍຈຸດ '.'."

#: pyanaconda/network.py:119
msgid ""
"Host names can only contain the characters 'a-z', 'A-Z', '0-9', '-', or '.', "
"parts between periods must contain something and cannot start or end with "
"'-'."
msgstr ""
"ຊື່ໂຮສຕ໌ສາມາດມີພຽງຕົວອັກສອນ 'a-z', 'A-Z', '0-9', '-', ຫຼື '.', ພາກສ່ວນລະຫວ່າງຈຸດຕ້ອງມີຂໍ້ຄວາ"
"ມ ແລະ ບໍ່ສາມາດເລີ່ມຕົ້ນ ຫຼື ລົງທ້າຍດ້ວຍ '-'."

#: pyanaconda/network.py:465
