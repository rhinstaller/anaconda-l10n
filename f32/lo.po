#: pyanaconda/platform.py:166
msgid "Apple EFI Boot Partition"
msgstr "ພາທິຊັນບູດ Apple EFI"

#: pyanaconda/platform.py:169
msgid ""
"For a UEFI installation, you must include a Linux HFS+ ESP on a GPT-"
"formatted disk, mounted at /boot/efi."
msgstr ""
"ສຳລັບການຕິດຕັ້ງແບບ UEFI, ທ່ານຕ້ອງລວມເອົາ Linux HFS+ ESP ເທິງດິສທີ່ຟໍແມັດແບບ GPT, ໂດຍເຊື່ອມຕໍ່ "
"(mount) ໄວ້ທີ່ /boot/efi."

#: pyanaconda/platform.py:201
msgid "PReP Boot Partition"
msgstr "ພາທິຊັນບູດ PReP"

#: pyanaconda/platform.py:203
msgid ""
"You must include a PReP Boot Partition within the first 4GiB of an MBR- or "
"GPT-formatted disk."
msgstr ""
"ທ່ານຕ້ອງລວມເອົາພາທິຊັນບູດ PReP ພາຍໃນ 4GiB ທຳອິດຂອງດິສທີ່ຟໍແມັດແບບ MBR ຫຼື GPT."

#: pyanaconda/platform.py:215
msgid "Apple Bootstrap Partition"
msgstr "ພາທິຊັນ Apple Bootstrap"

#: pyanaconda/platform.py:218
msgid ""
"You must include an Apple Bootstrap Partition on an Apple Partition Map-"
"formatted disk."
msgstr ""
"ທ່ານຕ້ອງລວມເອົາພາທິຊັນ Apple Bootstrap ເທິງດິສທີ່ຟໍແມັດແບບ Apple Partition Map."

#: pyanaconda/platform.py:230
msgid "You must include at least one disk as an install target."
msgstr "ທ່ານຕ້ອງລວມເອົາດິສຢ່າງໜ້ອຍໜຶ່ງໜ່ວຍເປັນເປົ້າໝາຍການຕິດຕັ້ງ."

#: pyanaconda/platform.py:240
msgid "DASD"
msgstr "DASD"

#: pyanaconda/platform.py:242
msgid "zFCP"
msgstr "zFCP"

#: pyanaconda/platform.py:247
msgid ""
"You must include at least one MBR- or DASD-formatted disk as an install "
"target."
msgstr ""
"ທ່ານຕ້ອງລວມເອົາດິສທີ່ຟໍແມັດແບບ MBR ຫຼື DASD ຢ່າງໜ້ອຍໜຶ່ງໜ່ວຍເປັນເປົ້າໝາຍການຕິດຕັ້ງ."

#: pyanaconda/platform.py:261
msgid "You must include at least one MBR-formatted disk as an install target."
msgstr ""
"ທ່ານຕ້ອງລວມເອົາດິສທີ່ຟໍແມັດແບບ MBR ຢ່າງໜ້ອຍໜຶ່ງໜ່ວຍເປັນເປົ້າໝາຍການຕິດຕັ້ງ."

#: pyanaconda/product.py:56
#, python-format
msgid "%(productName)s %(productVersion)s INSTALLATION"
msgstr "ການຕິດຕັ້ງ %(productName)s %(productVersion)s"

#: pyanaconda/pwpolicy.py:146
#, python-format
msgid "policy name required for %s"
msgstr "ຕ້ອງການຊື່ນະໂຍບາຍສຳລັບ %s"

#: pyanaconda/pwpolicy.py:155
#, python-format
msgid "A %(command)s with the name %(policyName)s has already been defined."
msgstr "%(command)s ທີ່ມີຊື່ %(policyName)s ຖືກກຳນົດໄວ້ແລ້ວ."

#: pyanaconda/rescue.py:272
msgid "Unable to find /bin/bash to execute!  Not starting shell."
msgstr "ບໍ່ສາມາດຊອກຫາ /bin/bash ເພື່ອປະມວນຜົນ! ຈະບໍ່ເລີ່ມການເຮັດວຽກຂອງ shell."

#: pyanaconda/rescue.py:289
msgid "Rescue"
msgstr "ກູ້ຄືນ (Rescue)"

#: pyanaconda/rescue.py:296
#, python-format
msgid ""
"The rescue environment will now attempt to find your Linux installation and "
"mount it under the directory : %s.  You can then make any changes required "
"to your system.  Choose '1' to proceed with this step.\n"
"You can choose to mount your file systems read-only instead of read-write by "
"choosing '2'.\n"
"If for some reason this process does not work choose '3' to skip directly to "
"a shell.\n"
"\n"
msgstr ""
"ລະບົບກູ້ຄືນຈະພະຍາຍາມຊອກຫາການຕິດຕັ້ງ Linux ຂອງທ່ານ ແລະ ເຊື່ອມຕໍ່ມັນໄວ້ພາຍໃຕ້ໄດເຣັກທໍຣີ: %s. ຈາກນັ້"
"ນທ່ານສາມາດປ່ຽນແປງສິ່ງຕ່າງໆທີ່ຈຳເປັນຕໍ່ລະບົບຂອງທ່ານໄດ້. ເລືອກ '1' ເພື່ອດຳເນີນການຕໍ່ໃນຂັ້ນຕອນນີ້.\n"
"ທ່ານສາມາດເລືອກເຊື່ອມຕໍ່ລະບົບໄຟລ໌ຂອງທ່ານແບບອ່ານຢ່າງດຽວ (read-only) ແທນທີ່ຈະເປັນແບບອ່ານ-ຂຽນ "
"(read-write) ໂດຍການເລືອກ '2'.\n"
"ຫາກຂັ້ນຕອນນີ້ໃຊ້ການບໍ່ໄດ້ຍ້ອນເຫດຜົນບາງຢ່າງ ໃຫ້ເລືອກ '3' ເພື່ອຂ້າມໄປໃຊ້ shell ໂດຍກົງ.\n"
"\n"

#: pyanaconda/rescue.py:308
msgid "Continue"
msgstr "ດຳເນີນການຕໍ່"

#: pyanaconda/rescue.py:309
msgid "Read-only mount"
msgstr "ເຊື່ອມຕໍ່ແບບອ່ານຢ່າງດຽວ"

#: pyanaconda/rescue.py:310
msgid "Skip to shell"
msgstr "ຂ້າມໄປຫາ shell"

#: pyanaconda/rescue.py:311
msgid "Quit (Reboot)"
msgstr "ອອກ (ເລີ່ມລະບົບໃໝ່)"

#: pyanaconda/rescue.py:408
msgid "Rescue Shell"
msgstr "Shell ກູ້ຄືນ"

#: pyanaconda/rescue.py:418
#, python-format
msgid "Run %s to unmount the system when you are finished."
msgstr "ຣັນ %s ເພື່ອຍົກເລີກການເຊື່ອມຕໍ່ລະບົບເມື່ອທ່ານເຮັດວຽກສຳເລັດແລ້ວ."

#: pyanaconda/rescue.py:419
msgid ""
"When finished, please exit from the shell and your system will reboot.\n"
msgstr "ເມື່ອສຳເລັດແລ້ວ, ກະລຸນາອອກຈາກ shell ແລະ ລະບົບຂອງທ່ານຈະເລີ່ມໃໝ່.\n"

#: pyanaconda/rescue.py:430
#, python-format
msgid ""
"Your system has been mounted under %(mountpoint)s.\n"
"\n"
"If you would like to make the root of your system the root of the active "
"system, run the command:\n"
"\n"
"\tchroot %(mountpoint)s\n"
"\n"
msgstr ""
"ລະບົບຂອງທ່ານຖືກເຊື່ອມຕໍ່ໄວ້ພາຍໃຕ້ %(mountpoint)s.\n"
"\n"
"ຫາກທ່ານຕ້ອງການເຮັດໃຫ້ຮາກ (root) ຂອງລະບົບທ່ານ ກາຍເປັນຮາກຂອງລະບົບທີ່ກຳລັງໃຊ້ງານຢູ່, ໃຫ້ຣັນຄຳສັ່"
"ງ:\n"
"\n"
"\tchroot %(mountpoint)s\n"
"\n"

#: pyanaconda/rescue.py:442
#, python-brace-format
msgid ""
"An error occurred trying to mount some or all of your system: {message}\n"
"\n"
"Some of it may be mounted under {path}."
msgstr ""
"ເກີດຂໍ້ຜິດພາດໃນການພະຍາຍາມເຊື່ອມຕໍ່ບາງສ່ວນ ຫຼື ທັງໝົດຂອງລະບົບຂອງທ່ານ: {message}\n"
"\n"
"ບາງສ່ວນອາດຖືກເຊື່ອມຕໍ່ໄວ້ພາຍໃຕ້ {path}."

#: pyanaconda/rescue.py:451
msgid "Rebooting."
msgstr "ກຳລັງເລີ່ມລະບົບໃໝ່."

#: pyanaconda/rescue.py:454
#, python-format
msgid "You don't have any Linux partitions. %s\n"
msgstr "ທ່ານບໍ່ມີພາທິຊັນ Linux ໃດໆເລີຍ. %s\n"

#: pyanaconda/rescue.py:460
msgid "Not mounting the system.\n"
msgstr "ຈະບໍ່ເຊື່ອມຕໍ່ລະບົບ.\n"

#: pyanaconda/rescue.py:474
#, python-format
msgid "Please press %s to get a shell"
msgstr "ກະລຸນາກົດ %s ເພື່ອເຂົ້າຫາ shell"

#: pyanaconda/rescue.py:491
msgid "Root Selection"
msgstr "ການເລືອກ Root"

#: pyanaconda/rescue.py:517
msgid "The following installations were discovered on your system."
msgstr "ພົບການຕິດຕັ້ງຕໍ່ໄປນີ້ໃນລະບົບຂອງທ່ານ."

#: pyanaconda/errors.py:112
msgid "An error occurred while activating your storage configuration."
msgstr "ເກີດຂໍ້ຜິດພາດຂະນະທີ່ກຳລັງເປີດໃຊ້ການຕັ້ງຄ່າບ່ອນເກັບຂໍ້ມູນຂອງທ່ານ."

#: pyanaconda/errors.py:119
msgid ""
"There is a problem with your existing storage configuration.You must resolve "
"this matter before the installation can proceed. There is a shell available "
"for use which you can access by pressing ctrl-alt-f1 and then ctrl-b 2.\n"
"\n"
"Once you have resolved the issue you can retry the storage scan. If you do "
"not fix it you will have to exit the installer."
msgstr ""
"ມີບັນຫາກັບການຕັ້ງຄ່າບ່ອນເກັບຂໍ້ມູນທີ່ມີຢູ່ຂອງທ່ານ. ທ່ານຕ້ອງແກ້ໄຂບັນຫານີ້ກ່ອນທີ່ການຕິດຕັ້ງຈະດຳເນີນການຕໍ່ໄດ້. ມີ "
"shell ໃຫ້ໃຊ້ງານເຊິ່ງທ່ານສາມາດເຂົ້າເຖິງໄດ້ໂດຍການກົດ ctrl-alt-f1 ແລະ ຕາມດ້ວຍ ctrl-b 2.\n"
"\n"
"ເມື່ອທ່ານແກ້ໄຂບັນຫາແລ້ວ ທ່ານສາມາດລອງສະແກນບ່ອນເກັບຂໍ້ມູນຄືນໃໝ່ໄດ້. ຫາກທ່ານບໍ່ແກ້ໄຂມັນ ທ່ານຈະຕ້ອງອອກຈ"
"າກຕົວຕິດຕັ້ງ."

#: pyanaconda/errors.py:128
msgctxt "GUI|Storage Detailed Error Dialog"
msgid "_Exit Installer"
msgstr "ອອກຈາກຕົວຕິດຕັ້ງ"

#: pyanaconda/errors.py:129
msgctxt "GUI|Storage Detailed Error Dialog"
msgid "_Retry"
msgstr "ລອງໃໝ່"

#: pyanaconda/errors.py:136
#, python-format
msgid ""
"The ISO image %s has a size which is not a multiple of 2048 bytes.  This may "
"mean it was corrupted on transfer to this computer.\n"
"\n"
"It is recommended that you exit and abort your installation, but you can "
"choose to continue if you think this is in error. Would you like to continue "
"using this image?"
msgstr ""
"ໄຟລ໌ອິມເມດ ISO %s ມີຂະໜາດທີ່ບໍ່ແມ່ນຜົນຄູນຂອງ 2048 ໄບຕ໌. ນີ້ອາດໝາຍຄວາມວ່າມັນເກີດຄວາມເສຍຫາຍໃນລະ"
"ຫວ່າງການສົ່ງຂໍ້ມູນມາຍັງຄອມພິວເຕີເຄື່ອງນີ້.\n"
"\n"
"ຂໍແນະນຳໃຫ້ທ່ານອອກ ແລະ ຍົກເລີກການຕິດຕັ້ງຂອງທ່ານ, ແຕ່ທ່ານສາມາດເລືອກທີ່ຈະດຳເນີນການຕໍ່ໄດ້ຫາກທ່ານຄິດວ່າ"
"ຂໍ້ມູນນີ້ຜິດພາດ. ທ່ານຕ້ອງການໃຊ້ໄຟລ໌ອິມເມດນີ້ຕໍ່ໄປບໍ່?"

#: pyanaconda/errors.py:150
msgid ""
"The installer has tried to mount the installation image, but cannot find it "
"on the hard drive.\n"
"\n"
"Should I try again to locate the image?"
msgstr ""
"ຕົວຕິດຕັ້ງໄດ້ພະຍາຍາມເຊື່ອມຕໍ່ອິມເມດການຕິດຕັ້ງແລ້ວ, ແຕ່ບໍ່ສາມາດຊອກຫາມັນເຫັນໃນຮາດດິສ.\n"
"\n"
"ໃຫ້ລອງຊອກຫາອິມເມດອີກຄັ້ງບໍ່?"

#: pyanaconda/errors.py:161
#, python-format
msgid ""
"The group '%s' is required for this installation. This group does not exist. "
"This is a fatal error and installation will be aborted."
msgstr ""
"ຕ້ອງການກຸ່ມ '%s' ສຳລັບການຕິດຕັ້ງນີ້. ກຸ່ມນີ້ບໍ່ມີຢູ່. ນີ້ແມ່ນຂໍ້ຜິດພາດຮ້າຍແຮງ ແລະ ການຕິດຕັ້ງຈະຖືກຍົກເລີກ."

#: pyanaconda/errors.py:167
#, python-format
msgid ""
"You have specified that the group '%s' should be installed.  This group does "
"not exist.  Would you like to ignore this group and continue with "
"installation?"
msgstr ""
"ທ່ານໄດ້ລະບຸວ່າຄວນຕິດຕັ້ງກຸ່ມ '%s'. ກຸ່ມນີ້ບໍ່ມີຢູ່. ທ່ານຕ້ອງການລະເວັ້ນກຸ່ມນີ້ ແລະ ດຳເນີນການຕິດຕັ້ງຕໍ່ບໍ່?"

#: pyanaconda/errors.py:172
#, python-format
msgid ""
"You have specified that the group '%s' should be excluded from "
"installation.  This group does not exist.  Would you like to ignore this "
"group and continue with installation?"
msgstr ""
"ທ່ານໄດ້ລະບຸວ່າຄວນຍົກເວັ້ນກຸ່ມ '%s' ຈາກການຕິດຕັ້ງ. ກຸ່ມນີ້ບໍ່ມີຢູ່. ທ່ານຕ້ອງການລະເວັ້ນກຸ່ມນີ້ ແລະ ດຳເນີນການຕິ"
"ດຕັ້ງຕໍ່ບໍ່?"

#: pyanaconda/errors.py:193
msgid ""
"Some packages, groups or modules are broken, the installation will be "
"aborted."
msgstr "ບາງແພັກເກດ, ກຸ່ມ ຫຼື ໂມດູນ ເປ່ເພ, ການຕິດຕັ້ງຈະຖືກຍົກເລີກ."

#: pyanaconda/errors.py:199
msgid "Would you like to ignore this and continue with installation?"
msgstr "ທ່ານຕ້ອງການລະເວັ້ນສິ່ງນີ້ ແລະ ດຳເນີນການຕິດຕັ້ງຕໍ່ບໍ່?"

#: pyanaconda/errors.py:206
#, python-format
msgid ""
"Stream was not specified for a module without a default stream. This is a "
"fatal error and installation will be aborted. The details of this error "
"are:\n"
"\n"
"%(exception)s"
msgstr ""
"ບໍ່ໄດ້ລະບຸ Stream ສຳລັບໂມດູນທີ່ບໍ່ມີ stream ເລີ່ມຕົ້ນ. ນີ້ແມ່ນຂໍ້ຜິດພາດຮ້າຍແຮງ ແລະ ການຕິດຕັ້ງຈະຖືກຍົກເລີ"
"ກ. ລາຍລະອຽດຂອງຂໍ້ຜິດພາດນີ້ຄື:\n"
"\n"
"%(exception)s"

#: pyanaconda/errors.py:214
#, python-format
msgid ""
"Multiple streams have been specified for a single module. This is a fatal "
"error and installation will be aborted. The details of this error are:\n"
"\n"
"%(exception)s"
msgstr ""
"ມີການລະບຸຫຼາຍ streams ສຳລັບໂມດູນດຽວ. ນີ້ແມ່ນຂໍ້ຜິດພາດຮ້າຍແຮງ ແລະ ການຕິດຕັ້ງຈະຖືກຍົກເລີກ. ລາຍລະອ"
"ຽດຂອງຂໍ້ຜິດພາດນີ້ຄື:\n"
"\n"
"%(exception)s"

#: pyanaconda/errors.py:222
#, python-format
msgid ""
"There was an error running the kickstart script at line %(lineno)s.  This is "
"a fatal error and installation will be aborted.  The details of this error "
