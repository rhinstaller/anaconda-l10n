msgid "part --noformat must also use the --onpart option."
msgstr "part --noformat ຕ້ອງໃຊ້ຕົວເລືອກ --onpart ນຳ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:268
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:378
#, python-format
msgid "Partition \"%s\" given in part command does not exist."
msgstr "ພາທິຊັນ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ part ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:281
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:292
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:389
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:970
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:981
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1046
#, python-format
msgid "Target size \"%(size)s\" for device \"%(device)s\" is invalid."
msgstr "ຂະໜາດເປົ້າໝາຍ \"%(size)s\" ສຳລັບອຸປະກອນ \"%(device)s\" ບໍ່ຖືກຕ້ອງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:313
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:615
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1021
#, python-format
msgid "The \"%s\" file system type is not supported."
msgstr "ບໍ່ຮອງຮັບປະເພດລະບົບໄຟລ໌ \"%s\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:329
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:348
#, python-format
msgid "Disk \"%s\" given in part command does not exist."
msgstr "ດິດ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ part ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:334
#, python-format
msgid "Cannot install to unpartitionable device \"%s\"."
msgstr "ບໍ່ສາມາດຕິດຕັ້ງລົງໃນອຸປະກອນທີ່ແບ່ງພາທິຊັນບໍ່ໄດ້ \"%s\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:342
#, python-format
msgid "Disk \"%s\" in part command is not partitioned."
msgstr "ດິດ \"%s\" ໃນຄຳສັ່ງ part ຍັງບໍ່ໄດ້ແບ່ງພາທິຊັນ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:359
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1091
#, python-format
msgid "The maximum size \"%s\" is invalid."
msgstr "ຂະໜາດສູງສຸດ \"%s\" ບໍ່ຖືກຕ້ອງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:549
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:915
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1257
#, python-format
msgid "The mount point \"%s\" is not valid.  It must start with a /."
msgstr "ຈຸດເມົາທ໌ \"%s\" ບໍ່ຖືກຕ້ອງ. ມັນຕ້ອງຂຶ້ນຕົ້ນດ້ວຍ /."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:558
msgid "raid --noformat must also use the --device option."
msgstr "raid --noformat ຕ້ອງໃຊ້ຕົວເລືອກ --device ນຳ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:565
#, python-format
msgid "RAID device  \"%s\" given in raid command does not exist."
msgstr "ອຸປະກອນ RAID \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ raid ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:590
#, python-format
msgid ""
"RAID device \"%(device)s\" has a format of \"%(format)s\", but should have a "
"format of \"mdmember\"."
msgstr ""
"ອຸປະກອນ RAID \"%(device)s\" ມີຮູບແບບເປັນ \"%(format)s\", ແຕ່ຄວນຈະມີຮູບແບບເປັນ "
"\"mdmember\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:597
#, python-format
msgid "Tried to use undefined partition \"%s\" in RAID specification."
msgstr "ພະຍາຍາມໃຊ້ພາທິຊັນທີ່ບໍ່ໄດ້ກຳນົດ \"%s\" ໃນການລະບຸ RAID."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:638
#, python-format
msgid "RAID volume \"%s\" specified with --useexisting does not exist."
msgstr "ວໍລຸມ RAID \"%s\" ທີ່ລະບຸດ້ວຍ --useexisting ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:649
#, python-format
msgid "The RAID volume name \"%s\" is already in use."
msgstr "ຊື່ວໍລຸມ RAID \"%s\" ຖືກນຳໃຊ້ແລ້ວ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:767
#, python-format
msgid ""
"Physical volume \"%(device)s\" has a format of \"%(format)s\", but should "
"have a format of \"lvmpv\"."
msgstr ""
"ວໍລຸມທາງກາຍະພາບ \"%(device)s\" ມີຮູບແບບເປັນ \"%(format)s\", ແຕ່ຄວນຈະມີຮູບແບບເປັນ "
"\"lvmpv\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:773
#, python-format
msgid "Tried to use undefined partition \"%s\" in Volume Group specification"
msgstr "ພະຍາຍາມໃຊ້ພາທິຊັນທີ່ບໍ່ໄດ້ກຳນົດ \"%s\" ໃນການລະບຸ Volume Group"

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:781
#, python-format
msgid ""
"Volume group \"%s\" defined without any physical volumes.  Either specify "
"physical volumes or use --useexisting."
msgstr ""
"ກຸ່ມວໍລຸມ \"%s\" ຖືກກຳນົດໂດຍບໍ່ມີວໍລຸມທາງກາຍະພາບ. ກະລຸນາລະບຸວໍລຸມທາງກາຍະພາບ ຫຼື ໃຊ້ --"
"useexisting."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:794
#, python-format
msgid ""
"Volume group given physical extent size of \"%(extentSize)s\", but must be "
"one of:\n"
"%(validExtentSizes)s."
msgstr ""
"ກຸ່ມວໍລຸມຖືກກຳນົດຂະໜາດ physical extent ເປັນ \"%(extentSize)s\", ແຕ່ຕ້ອງເປັນໜຶ່ງໃນ:\n"
"%(validExtentSizes)s."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:807
msgid ""
"volgroup --noformat and volgroup --useexisting must also use the --name= "
"option."
msgstr ""
"volgroup --noformat ແລະ volgroup --useexisting ຕ້ອງໃຊ້ຕົວເລືອກ --name= ນຳ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:814
#, python-format
msgid "Volume group \"%s\" given in volgroup command does not exist."
msgstr "ກຸ່ມວໍລຸມ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ volgroup ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:819
#, python-format
msgid "The volume group name \"%s\" is already in use."
msgstr "ຊື່ກຸ່ມວໍລຸມ \"%s\" ຖືກນຳໃຊ້ແລ້ວ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:923
#, python-format
msgid ""
"No volume group exists with the name \"%s\".  Specify volume groups before "
"logical volumes."
msgstr "ບໍ່ມີກຸ່ມວໍລຸມຊື່ \"%s\". ໃຫ້ລະບຸກຸ່ມວໍລຸມກ່ອນວໍລຸມໂລຈິກ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:932
msgid "Cache PVs must belong to the same VG as the cached LV"
msgstr "PV ສຳລັບແຄຊຕ້ອງຢູ່ໃນ VG ດຽວກັນກັບ LV ທີ່ຖືກແຄຊ"

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:941
#, python-format
msgid ""
"No thin pool exists with the name \"%s\". Specify thin pools before thin "
"volumes."
msgstr "ບໍ່ມີ thin pool ຊື່ \"%s\". ໃຫ້ລະບຸ thin pool ກ່ອນ thin volume."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:950
msgid "logvol --noformat must also use the --name= option."
msgstr "logvol --noformat ຕ້ອງໃຊ້ຕົວເລືອກ --name= ນຳ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:957
#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1034
#, python-format
msgid "Logical volume \"%s\" given in logvol command does not exist."
msgstr "ວໍລຸມໂລຈິກ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ logvol ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:997
#, python-format
msgid ""
"Logical volume name \"%(logvol)s\" is already in use in volume group "
"\"%(volgroup)s\"."
msgstr "ຊື່ວໍລຸມໂລຈິກ \"%(logvol)s\" ຖືກນຳໃຊ້ແລ້ວໃນກຸ່ມວໍລຸມ \"%(volgroup)s\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1004
#, python-format
msgid ""
"Logical volume size \"%(logvolSize)s\" must be larger than the volume group "
"extent size of \"%(extentSize)s\"."
msgstr ""
"ຂະໜາດວໍລຸມໂລຈິກ \"%(logvolSize)s\" ຕ້ອງໃຫຍ່ກວ່າຂະໜາດ extent ຂອງກຸ່ມວໍລຸມ \"%"
"(extentSize)s\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1223
#, python-format
msgid ""
"Btrfs partition \"%(device)s\" has a format of \"%(format)s\", but should "
"have a format of \"btrfs\"."
msgstr ""
"ພາທິຊັນ Btrfs \"%(device)s\" ມີຮູບແບບເປັນ \"%(format)s\", ແຕ່ຄວນຈະມີຮູບແບບເປັນ "
"\"btrfs\"."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1231
#, python-format
msgid "Tried to use undefined partition \"%s\" in Btrfs volume specification."
msgstr "ພະຍາຍາມໃຊ້ພາທິຊັນທີ່ບໍ່ໄດ້ກຳນົດ \"%s\" ໃນການລະບຸວໍລຸມ Btrfs."

#: pyanaconda/modules/storage/partitioning/custom/custom_partitioning.py:1246
msgid ""
"Btrfs volume defined without any member devices.  Either specify member "
