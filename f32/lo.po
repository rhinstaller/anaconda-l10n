msgstr "ອຸປະກອນ \"{}\" ທີ່ກຳນົດໃນລາຍຊື່ອຸປະກອນ clearpart ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/kickstart.py:117
#: pyanaconda/modules/storage/kickstart.py:122
msgid "Disk \"{}\" given in ignoredisk command does not exist."
msgstr "ດິດ \"{}\" ທີ່ກຳນົດໃນຄຳສັ່ງ ignoredisk ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/kickstart.py:132
msgid "NIC \"{}\" given in fcoe command does not exist."
msgstr "NIC \"{}\" ທີ່ກຳນົດໃນຄຳສັ່ງ fcoe ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/kickstart.py:157
#, python-brace-format
msgid ""
"Network interface \"{nic}\" required by iSCSI \"{iscsi_target}\" target is "
"not up."
msgstr ""
"ອິນເຕີເຟດເຄືອຂ່າຍ \"{nic}\" ທີ່ຕ້ອງການໂດຍເປົ້າໝາຍ iSCSI \"{iscsi_target}\" ຍັງບໍ່ໄດ້ເປີດໃຊ້ງ"
"ານ."

#: pyanaconda/modules/storage/kickstart.py:173
msgid ""
"iscsi --iface must be specified (binding used) either for all targets or for "
"none"
msgstr "ຕ້ອງລະບຸ iscsi --iface (ໃຊ້ການຜູກມັດ) ສຳລັບທຸກເປົ້າໝາຍ ຫຼື ບໍ່ລະບຸເລີຍ"

#: pyanaconda/modules/storage/kickstart.py:211
#: pyanaconda/modules/storage/kickstart.py:223
msgid "Namespace \"{}\" given in nvdimm command was not found."
msgstr "ບໍ່ພົບ Namespace \"{}\" ທີ່ກຳນົດໃນຄຳສັ່ງ nvdimm."

#: pyanaconda/modules/storage/kickstart.py:228
msgid "Disk \"{}\" given in nvdimm command does not exist."
msgstr "ດິດ \"{}\" ທີ່ກຳນົດໃນຄຳສັ່ງ nvdimm ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/modules/storage/kickstart.py:241
msgid ""
"Incorrectly specified origin of the snapshot. Use format \"VolGroup/LV-name\""
msgstr "ລະບຸຕົ້ນທາງຂອງສະແນບຊັອດບໍ່ຖືກຕ້ອງ. ໃຫ້ໃຊ້ຮູບແບບ \"VolGroup/LV-name\""

#: pyanaconda/modules/storage/bootloader/bootloader.py:160
msgid "GRUB2 does not support installation to a partition."
msgstr "GRUB2 ບໍ່ຮອງຮັບການຕິດຕັ້ງລົງໃນພາທິຊັນ."

#: pyanaconda/modules/storage/bootloader/bootloader.py:167
msgid "GRUB2 encrypted password must be in grub.pbkdf2 format."
msgstr "ລະຫັດຜ່ານທີ່ເຂົ້າລະຫັດຂອງ GRUB2 ຕ້ອງຢູ່ໃນຮູບແບບ grub.pbkdf2."

#: pyanaconda/modules/storage/installation.py:80
msgid "An error occurred while resizing the device {}: {}"
msgstr "ເກີດຂໍ້ຜິດພາດໃນຂະນະທີ່ປັບຂະໜາດອຸປະກອນ {}: {}"

#: pyanaconda/modules/storage/installation.py:131
msgid "Gathering entropy 100%"
msgstr "ກຳລັງເກັບກຳ entropy 100%"

#: pyanaconda/modules/storage/installation.py:135
msgid "Gathering entropy (time ran out)"
msgstr "ກຳລັງເກັບກຳ entropy (ໝົດເວລາ)"

#: pyanaconda/modules/storage/installation.py:138
#, python-brace-format
msgid "Gathering entropy {percents}% (remaining time {time})"
msgstr "ກຳລັງເກັບກຳ entropy {percents}% (ເວລາທີ່ເຫຼືອ {time})"

#: pyanaconda/modules/storage/partitioning/manual/manual_partitioning.py:64
#, python-format
