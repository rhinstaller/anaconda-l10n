#: pyanaconda/bootloader.py:253
msgid "/boot file system"
msgstr "ລະບົບໄຟລ໌ /boot"

#: pyanaconda/bootloader.py:410
#, python-format
msgid ""
"RAID sets that contain '%(desc)s' must have one of the following raid "
"levels: %(raid_level)s."
msgstr ""
"ຊຸດ RAID ທີ່ມີ '%(desc)s' ຕ້ອງມີໜຶ່ງໃນລະດັບ RAID ຕໍ່ໄປນີ້: %(raid_level)s."

#: pyanaconda/bootloader.py:418
#, python-format
msgid ""
"RAID sets that contain '%(desc)s' must have one of the following metadata "
"versions: %(metadata_versions)s."
msgstr ""
"ຊຸດ RAID ທີ່ມີ '%(desc)s' ຕ້ອງມີໜຶ່ງໃນເວີຊັນ metadata ຕໍ່ໄປນີ້: %(metadata_versions)s."

#: pyanaconda/bootloader.py:426
#, python-format
msgid ""
"RAID sets that contain '%(desc)s' must have one of the following device "
"types: %(types)s."
msgstr "ຊຸດ RAID ທີ່ມີ '%(desc)s' ຕ້ອງມີໜຶ່ງໃນປະເພດອຸປະກອນຕໍ່ໄປນີ້: %(types)s."

#: pyanaconda/bootloader.py:442
#, python-format
msgid "%(name)s must have one of the following disklabel types: %(types)s."
msgstr "%(name)s ຕ້ອງມີໜຶ່ງໃນປະເພດປ້າຍຊື່ດິສກ໌ (disklabel) ຕໍ່ໄປນີ້: %(types)s."

#: pyanaconda/bootloader.py:454
#, python-format
msgid "%(desc)s cannot be of type %(type)s."
msgstr "%(desc)s ບໍ່ສາມາດເປັນປະເພດ %(type)s ໄດ້."

#: pyanaconda/bootloader.py:460
#, python-format
msgid "%(desc)s must be mounted on one of %(mountpoints)s."
msgstr "%(desc)s ຕ້ອງເຊື່ອມຕໍ່ກັບໜຶ່ງໃນ %(mountpoints)s."

#: pyanaconda/bootloader.py:472
#, python-format
msgid "%(desc)s must be between %(min)d and %(max)d MB in size"
msgstr "%(desc)s ຕ້ອງມີຂະໜາດລະຫວ່າງ %(min)d ຫາ %(max)d MB"

#: pyanaconda/bootloader.py:478
#, python-format
msgid "%(desc)s must not be smaller than %(min)dMB."
msgstr "%(desc)s ຕ້ອງບໍ່ນ້ອຍກວ່າ %(min)dMB."

#: pyanaconda/bootloader.py:487
#, python-format
msgid "%(desc)s must not be larger than %(max)dMB."
msgstr "%(desc)s ຕ້ອງບໍ່ໃຫຍ່ກວ່າ %(max)dMB."

#: pyanaconda/bootloader.py:505
#, python-format
msgid "%(desc)s must be within the first %(max_end)s of the disk."
msgstr "%(desc)s ຕ້ອງຢູ່ພາຍໃນ %(max_end)s ທຳອິດຂອງດິສກ໌."

#: pyanaconda/bootloader.py:515
#, python-format
msgid "%s must be on a primary partition."
msgstr "%s ຕ້ອງຢູ່ໃນພາຕິຊັນຫຼັກ."

#: pyanaconda/bootloader.py:599
msgid ""
"Boot loader stage1 device cannot be on an iSCSI disk which is not configured "
"in iBFT."
msgstr ""
"ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 1 ບໍ່ສາມາດຢູ່ໃນດິສກ໌ iSCSI ທີ່ບໍ່ໄດ້ຕັ້ງຄ່າໃນ iBFT."

#: pyanaconda/bootloader.py:656 pyanaconda/bootloader.py:767
#, python-format
msgid "%s cannot be on an encrypted block device."
msgstr "%s ບໍ່ສາມາດຢູ່ໃນອຸປະກອນບລັອກທີ່ເຂົ້າລະຫັດໄດ້."

#: pyanaconda/bootloader.py:721
#, python-format
msgid ""
"%(bootloader_stage2_description)s cannot be on an iSCSI disk which is not "
"configured in iBFT."
msgstr ""
"%(bootloader_stage2_description)s ບໍ່ສາມາດຢູ່ໃນດິສກ໌ iSCSI ທີ່ບໍ່ໄດ້ຕັ້ງຄ່າໃນ iBFT."

#: pyanaconda/bootloader.py:726
#, python-format
msgid "%(desc)s cannot be of type %(type)s"
msgstr "%(desc)s ບໍ່ສາມາດເປັນປະເພດ %(type)s"

#: pyanaconda/bootloader.py:1377
#, python-format
msgid ""
"boot loader stage2 device %(stage2dev)s is on a multi-disk array, but boot "
"loader stage1 device %(stage1dev)s is not. A drive failure in %(stage2dev)s "
"could render the system unbootable."
msgstr ""
"ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 2 %(stage2dev)s ຢູ່ໃນອາເຣແບບຫຼາຍດິສກ໌, ແຕ່ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 1 %"
"(stage1dev)s ບໍ່ໄດ້ຢູ່. ຖ້າດິສກ໌ໃນ %(stage2dev)s ເພພັງອາດຈະເຮັດໃຫ້ລະບົບບໍ່ສາມາດບູດໄດ້."

#: pyanaconda/bootloader.py:1383
#, python-format
msgid ""
"boot loader stage2 device %(stage2dev)s is on a multi-disk array, but boot "
"loader stage1 device %(stage1dev)s is not part of this array. The stage1 "
"boot loader will only be installed to a single drive."
msgstr ""
"ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 2 %(stage2dev)s ຢູ່ໃນອາເຣແບບຫຼາຍດິສກ໌, ແຕ່ອຸປະກອນຕົວໂຫຼດບູດລະດັບ 1 %"
"(stage1dev)s ບໍ່ໄດ້ເປັນສ່ວນໜຶ່ງຂອງອາເຣນີ້. ຕົວໂຫຼດບູດລະດັບ 1 ຈະຖືກຕິດຕັ້ງໃສ່ດິສກ໌ດຽວເທົ່ານັ້ນ."

#: pyanaconda/bootloader.py:1676
#, python-format
msgid ""
"%(deviceName)s may not have enough space for grub2 to embed core.img when "
"using the %(fsType)s file system on %(deviceType)s"
msgstr ""
"%(deviceName)s ອາດຈະບໍ່ມີພື້ນທີ່ພຽງພໍສຳລັບ grub2 ໃນການຝັງ core.img ເມື່ອໃຊ້ລະບົບໄຟລ໌ %"
"(fsType)s ໃນ %(deviceType)s"

#: pyanaconda/constants.py:73
msgid "Start VNC"
msgstr "ເລີ່ມ VNC"

#: pyanaconda/constants.py:74
msgid "Use text mode"
msgstr "ໃຊ້ໂໝດຂໍ້ຄວາມ"

#: pyanaconda/constants.py:141
msgid ""
"Simultaneous Multithreading (SMT) technology can provide performance "
"improvements for certain workloads, but introduces several publicly "
"disclosed security issues. You have the option of disabling SMT, which may "
"impact performance. If you choose to leave SMT enabled, please read https://"
"red.ht/rhel-smt to understand your potential risks and learn about other "
"ways to mitigate these risks."
msgstr ""
"ເຕັກໂນໂລຊີ Simultaneous Multithreading (SMT) ສາມາດຊ່ວຍປັບປຸງປະສິດທິພາບໃຫ້ກັບບາງວຽກທີ່ປະມ"
"ວນຜົນໄດ້, ແຕ່ກໍ່ມີບັນຫາດ້ານຄວາມປອດໄພທີ່ຖືກເປີດເຜີຍອອກມາຫຼາຍຢ່າງ. ທ່ານມີທາງເລືອກທີ່ຈະປິດການໃຊ້ງານ "
"SMT ເຊິ່ງອາດສົ່ງຜົນກະທົບຕໍ່ປະສິດທິພາບ. ຫາກທ່ານເລືອກທີ່ຈະເປີດໃຊ້ງານ SMT ຕໍ່ໄປ, ກະລຸນາອ່ານ https://"
"red.ht/rhel-smt ເພື່ອທຳຄວາມເຂົ້າໃຈກ່ຽວກັບຄວາມສ່ຽງທີ່ອາດເກີດຂຶ້ນ ແລະ ຮຽນຮູ້ວິທີອື່ນໆໃນການຫຼຸດຜ່ອນຄວ"
"າມສ່ຽງເຫຼົ່ານີ້."

#: pyanaconda/constants.py:150
msgid ""
"Simultaneous Multithreading (SMT) may improve performance for certain "
"workloads, but introduces several publicly disclosed security issues. You "
"can disable SMT, which may impact performance. Please read https://red.ht/"
"rhel-smt to understand potential risks and learn about ways to mitigate "
"these risks."
msgstr ""
"Simultaneous Multithreading (SMT) ອາດຊ່ວຍປັບປຸງປະສິດທິພາບໃຫ້ກັບບາງວຽກທີ່ປະມວນຜົນໄດ້, ແຕ່ກໍ່"
"ມີບັນຫາດ້ານຄວາມປອດໄພທີ່ຖືກເປີດເຜີຍອອກມາຫຼາຍຢ່າງ. ທ່ານສາມາດປິດການໃຊ້ງານ SMT ໄດ້ ເຊິ່ງອາດສົ່ງຜົນກະ"
"ທົບຕໍ່ປະສິດທິພາບ. ກະລຸນາອ່ານ https://red.ht/rhel-smt ເພື່ອທຳຄວາມເຂົ້າໃຈກ່ຽວກັບຄວາມສ່ຽງທີ່ອາດເ"
"ກີດຂຶ້ນ ແລະ ຮຽນຮູ້ວິທີໃນການຫຼຸດຜ່ອນຄວາມສ່ຽງເຫຼົ່ານີ້."

#: pyanaconda/constants.py:158
#, python-format
msgid "The %(password)s is empty."
msgstr "%(password)s ວ່າງເປົ່າ."

#: pyanaconda/constants.py:159
#, python-format
msgid "The %(passwords)s do not match."
msgstr "%(passwords)s ບໍ່ຕົງກັນ."

#: pyanaconda/constants.py:160
#, python-format
msgid "The %(passwords)s you entered were different.  Please try again."
msgstr "%(passwords)s ທີ່ທ່ານປ້ອນນັ້ນຕ່າງກັນ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#: pyanaconda/constants.py:163
#, python-format
msgid "The %(password)s is too short"
msgstr "%(password)s ສັ້ນເກີນໄປ"

#: pyanaconda/constants.py:164
#, python-format
msgid "The %(password)s you have provided is weak."
msgstr "%(password)s ທີ່ທ່ານຕັ້ງນັ້ນຍັງບໍ່ແຂງແຮງພໍ (ອ່ອນແອ)."

#: pyanaconda/constants.py:165
#, python-format
msgid "The %(password)s you have provided is weak: %(error_message)s."
msgstr "%(password)s ທີ່ທ່ານຕັ້ງນັ້ນຍັງບໍ່ແຂງແຮງພໍ: %(error_message)s."

#: pyanaconda/constants.py:166
msgid "Press Done again to use anyway."
msgstr "ກົດ \"ສຳເລັດ\" ອີກຄັ້ງຫາກຕ້ອງການຢືນຢັນການໃຊ້ງານ."

#: pyanaconda/constants.py:167
#, python-format
msgid ""
"The %(password)s you have provided contains non-ASCII characters. You may "
"not be able to switch between keyboard layouts when typing it."
msgstr ""
"%(password)s ທີ່ທ່ານຕັ້ງນັ້ນມີຕົວອັກສອນທີ່ບໍ່ແມ່ນ ASCII. ທ່ານອາດຈະບໍ່ສາມາດສະຫຼັບພາສາຄີບອດໄດ້ໃນເວລາພິ"
"ມລະຫັດນີ້."

#: pyanaconda/constants.py:169
msgid "You will have to press Done twice to confirm it."
msgstr "ທ່ານຕ້ອງກົດ \"ສຳເລັດ\" ສອງຄັ້ງເພື່ອຢືນຢັນ."

#: pyanaconda/constants.py:170
msgid "Press Done to continue."
msgstr "ກົດ \"ສຳເລັດ\" ເພື່ອດຳເນີນການຕໍ່."

#: pyanaconda/constants.py:173
