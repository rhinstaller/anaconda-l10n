msgstr "ປານກາງ"

#: pyanaconda/constants.py:177
msgid "Good"
msgstr "ດີ"

#: pyanaconda/constants.py:178
msgid "Strong"
msgstr "ແຂງແຮງ"

#: pyanaconda/constants.py:181
msgid "password"
msgstr "ລະຫັດຜ່ານ"

#: pyanaconda/constants.py:182
