#: pyanaconda/ui/gui/spokes/lib/resize.glade.h:4
msgid "Description goes here."
msgstr "ຄຳອະທິບາຍໃສ່ບ່ອນນີ້."

#: pyanaconda/ui/gui/spokes/lib/resize.glade.h:7
msgid "File System"
msgstr "ລະບົບໄຟລ໌"

#: pyanaconda/ui/gui/spokes/lib/resize.glade.h:8
