msgid "_Preserve"
msgstr "_ຮັກສາໄວ້"

#: pyanaconda/ui/gui/spokes/lib/resize.glade.h:11
msgctxt "GUI|Reclaim Dialog"
msgid "_Delete"
msgstr "_ລຶບ"

#: pyanaconda/ui/gui/spokes/lib/resize.glade.h:12
