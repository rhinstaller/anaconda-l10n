msgstr "ກຳລັງກຽມການຕິດຕັ້ງ"

#: pyanaconda/ui/gui/hubs/progress.glade.h:3
msgctxt "GUI|Progress"
msgid "_Finish configuration"
msgstr "_ຕັ້ງຄ່າໃຫ້ສຳເລັດ"

#: pyanaconda/ui/gui/hubs/progress.glade.h:4
msgctxt "GUI|Progress"
msgid "_Reboot"
msgstr "_ເລີ່ມລະບົບໃໝ່"

#: data/liveinst/liveinst.desktop.in.h:1
msgid "Install to Hard Drive"
msgstr "ຕິດຕັ້ງລົງຮາດໄດຣຟ໌"

#: data/liveinst/liveinst.desktop.in.h:2
msgid "Install"
msgstr "ຕິດຕັ້ງ"

#: data/liveinst/liveinst.desktop.in.h:3
msgid "Install the live CD to your hard disk"
msgstr "ຕິດຕັ້ງໄລຟ໌ CD ລົງໃນຮາດດິດຂອງທ່ານ"

#: /home/rvykydal/anaconda/data/liveinst/console.apps/liveinst:5
msgid "Starting Install to Hard Drive"
msgstr "ກຳລັງເລີ່ມຕິດຕັ້ງລົງຮາດໄດຣຟ໌"

#: data/liveinst/gnome/fedora-welcome.desktop.in.h:1
#: data/liveinst/gnome/fedora-welcome:65
msgid "Welcome to Fedora"
msgstr "ຍິນດີຕ້ອນຮັບສູ່ Fedora"

#: anaconda:490
#, python-format
msgid ""
"%(product_name)s requires %(needed_ram)s MB of memory to install, but you "
"only have %(total_ram)s MB on this machine.\n"
msgstr ""
"%(product_name)s ຕ້ອງການ %(needed_ram)s MB ເພື່ອຕິດຕັ້ງ, ແຕ່ທ່ານມີພຽງແຕ່ %(total_ram)s "
"MB ໃນເຄື່ອງນີ້.\n"

#: anaconda:492
#, python-format
msgid ""
"The %(product_name)s graphical installer requires %(needed_ram)s MB of "
"memory, but you only have %(total_ram)s MB\n"
"."
msgstr ""
"ຕົວຕິດຕັ້ງແບບກຣາຟິກຂອງ %(product_name)s ຕ້ອງການ %(needed_ram)s MB, ແຕ່ທ່ານມີພຽງແຕ່ %"
"(total_ram)s MB\n"
"."

#: anaconda:495
msgid ""
"\n"
"Press <return> to reboot your system.\n"
msgstr ""
"\n"
"ກົດ <return> ເພື່ອເລີ່ມລະບົບໃໝ່.\n"

#: anaconda:497
msgid "Not enough RAM"
msgstr "RAM ບໍ່ພຽງພໍ"

#: anaconda:498
msgid ""
" Try the text mode installer by running:\n"
"\n"
"'/usr/bin/liveinst -T'\n"
"\n"
" from a root terminal."
msgstr ""
" ລອງໃຊ້ຕົວຕິດຕັ້ງແບບຂໍ້ຄວາມ (text mode) ໂດຍການຣັນ:\n"
"\n"
"'/usr/bin/liveinst -T'\n"
"\n"
" ຈາກເທີມິນໍຣາກ (root terminal)."

#: anaconda:501
msgid " Starting text mode."
msgstr " ກຳລັງເລີ່ມໂໝດຂໍ້ຄວາມ."

#: anaconda:537
msgid "The installation cannot continue and the system will be rebooted"
msgstr "ການຕິດຕັ້ງບໍ່ສາມາດດຳເນີນການຕໍ່ໄດ້ ແລະ ລະບົບຈະຖືກເລີ່ມໃໝ່"

#: anaconda:664
msgid "DISPLAY variable not set. Starting text mode."
msgstr "ບໍ່ໄດ້ກຳນົດຕົວປ່ຽນ DISPLAY. ກຳລັງເລີ່ມໃນໂໝດຕົວໜັງສື."

#: anaconda:672
msgid "Graphical installation is not available. Starting text mode."
msgstr "ບໍ່ສາມາດໃຊ້ການຕິດຕັ້ງແບບກຣາຟິກໄດ້. ກຳລັງເລີ່ມໂໝດຂໍ້ຄວາມ."

#: anaconda:680
msgid ""
"Text mode provides a limited set of installation options. It does not offer "
"custom partitioning for full control over the disk layout. Would you like to "
"use VNC mode instead?"
msgstr ""
"ໂໝດຂໍ້ຄວາມມີຕົວເລືອກການຕິດຕັ້ງທີ່ຈຳກັດ. ມັນບໍ່ມີການແບ່ງພາທິຊັນແບບກຳນົດເອງເພື່ອຄວບຄຸມຮູບແບບດິສຢ່າງເຕັມສ່ວ"
"ນ. ທ່ານຕ້ອງການໃຊ້ໂໝດ VNC ແທນບໍ່?"

#: anaconda:776
#, python-format
msgid "Please ssh install@%s to begin the install."
msgstr "ກະລຸນາ ssh install@%s ເພື່ອເລີ່ມການຕິດຕັ້ງ."

#: anaconda:778
msgid "Please ssh install@<host> to continue installation."
msgstr "ກະລຸນາ ssh install@<host> ເພື່ອດຳເນີນການຕິດຕັ້ງຕໍ່."

#: data/liveinst/gnome/fedora-welcome:94
msgid "Try Fedora"
msgstr "ລອງໃຊ້ Fedora"

#: data/liveinst/gnome/fedora-welcome:110
msgid ""
"You are currently running Fedora from live media.\n"
"You can install Fedora now, or choose \"Install to Hard Drive\" in the "
"Activities Overview at any later time."
msgstr ""
"ປະຈຸບັນທ່ານກຳລັງໃຊ້ງານ Fedora ຈາກມີເດຍໄລຟ໌.\n"
"ທ່ານສາມາດຕິດຕັ້ງ Fedora ດຽວນີ້, ຫຼື ເລືອກ \"ຕິດຕັ້ງລົງຮາດໄດຣຟ໌\" ໃນພາບລວມຂອງກິດຈະກຳໄດ້ໃນພາຍຫຼັ"
"ງ."

#: data/liveinst/gnome/fedora-welcome:128
msgid ""
"You can choose \"Install to Hard Drive\"\n"
"in the Activities Overview at any later time."
msgstr ""
"ທ່ານສາມາດເລືອກ \"ຕິດຕັ້ງລົງຮາດໄດຣຟ໌\"\n"
"ໃນພາບລວມຂອງກິດຈະກຳໄດ້ໃນພາຍຫຼັງ."

#: data/liveinst/gnome/fedora-welcome:131
msgid "Close"
msgstr "ປິດ"
