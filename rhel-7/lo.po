msgstr "url ຜິດຮູບແບບ, ບໍ່ສາມາດແຍກວິເຄາະໄດ້."

#: pyanaconda/iutil.py:826
msgid "URL has no host component"
msgstr "URL ບໍ່ມີສ່ວນປະກອບຂອງໂຮສຕ໌"

#: pyanaconda/kickstart.py:191
#, python-format
msgid "Escrow certificate %s requires the network."
msgstr "ໃບຢັ້ງຢືນ Escrow %s ຕ້ອງການເຄືອຂ່າຍ."

#: pyanaconda/kickstart.py:199
#, python-format
msgid ""
"The following error was encountered while downloading the escrow "
"certificate:\n"
"\n"
"%s"
msgstr ""
"ພົບຂໍ້ຜິດພາດຕໍ່ໄປນີ້ໃນຂະນະທີ່ດາວໂຫຼດໃບຢັ້ງຢືນ Escrow:\n"
"\n"
"%s"

#: pyanaconda/kickstart.py:273
#, python-format
msgid "%s is missing. Cannot setup authentication."
msgstr "ບໍ່ພົບ %s. ບໍ່ສາມາດຕັ້ງຄ່າການຢືນຢັນຕົວຕົນໄດ້."

#: pyanaconda/kickstart.py:298
#, python-format
msgid "autopart fstype of %s is invalid."
msgstr "fstype ຂອງ autopart ໃນ %s ບໍ່ຖືກຕ້ອງ."

#: pyanaconda/kickstart.py:342
msgid "GRUB2 does not support installation to a partition."
msgstr "GRUB2 ບໍ່ຮອງຮັບການຕິດຕັ້ງລົງໃນພາທິຊັນ."

#: pyanaconda/kickstart.py:435
#, python-format
msgid "More than one match found for given boot drive \"%s\"."
msgstr "ພົບລາຍການທີ່ຕົງກັນຫຼາຍກວ່າໜຶ່ງສຳລັບໄດຣຟ໌ບູດ \"%s\" ທີ່ລະບຸ."

#: pyanaconda/kickstart.py:440
#, python-format
msgid "Requested boot drive \"%s\" doesn't exist or cannot be used."
msgstr "ໄດຣຟ໌ບູດ \"%s\" ທີ່ຮ້ອງຂໍບໍ່ມີຢູ່ ຫຼື ບໍ່ສາມາດໃຊ້ງານໄດ້."

#: pyanaconda/kickstart.py:514
#, python-format
msgid ""
"Btrfs partition \"%(device)s\" has a format of \"%(format)s\", but should "
"have a format of \"Btrfs\"."
msgstr ""
"ພາທິຊັນ Btrfs \"%(device)s\" ມີຟໍແມັດເປັນ \"%(format)s\", ແຕ່ຄວນຈະເປັນຟໍແມັດ \"Btrfs\"."

#: pyanaconda/kickstart.py:519
#, python-format
msgid "Tried to use undefined partition \"%s\" in Btrfs volume specification."
msgstr "ພະຍາຍາມໃຊ້ພາທິຊັນທີ່ບໍ່ໄດ້ກຳນົດ \"%s\" ໃນການລະບຸວໍລຸມ Btrfs."

#: pyanaconda/kickstart.py:532
msgid ""
"Btrfs volume defined without any member devices.  Either specify member "
"devices or use --useexisting."
msgstr ""
"ວໍລຸມ Btrfs ຖືກກຳນົດໂດຍບໍ່ມີອຸປະກອນສະມາຊິກ. ກະລຸນາລະບຸອຸປະກອນສະມາຊິກ ຫຼື ໃຊ້ --useexisting."

#: pyanaconda/kickstart.py:541 pyanaconda/kickstart.py:928
#: pyanaconda/kickstart.py:1593
#, python-format
msgid "The mount point \"%s\" is not valid.  It must start with a /."
msgstr "ຈຸດເມົາທ໌ \"%s\" ບໍ່ຖືກຕ້ອງ. ມັນຕ້ອງຂຶ້ນຕົ້ນດ້ວຍ /."

#: pyanaconda/kickstart.py:556
#, python-format
msgid "Btrfs volume \"%s\" specified with --useexisting does not exist."
msgstr "ວໍລຸມ Btrfs \"%s\" ທີ່ລະບຸດ້ວຍ --useexisting ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:640
#, python-format
msgid ""
"Disklabel \"%s\" given in clearpart command is not supported on this "
"platform."
msgstr "Disklabel \"%s\" ທີ່ລະບຸໃນຄຳສັ່ງ clearpart ບໍ່ຮອງຮັບໃນແພລັດຟອມນີ້."

#: pyanaconda/kickstart.py:652
#, python-format
msgid "Disk \"%s\" given in clearpart command does not exist."
msgstr "ດິສກ໌ \"%s\" ທີ່ລະບຸໃນຄຳສັ່ງ clearpart ບໍ່ມີຢູ່."

#: pyanaconda/kickstart.py:665
#, python-format
msgid "Device \"%s\" given in clearpart device list does not exist."
msgstr "ອຸປະກອນ \"%s\" ທີ່ລະບຸໃນລາຍການອຸປະກອນ clearpart ບໍ່ມີຢູ່."

#: pyanaconda/kickstart.py:692
#, python-format
msgid "NIC \"%s\" given in fcoe command does not exist."
msgstr "NIC \"%s\" ທີ່ລະບຸໃນຄຳສັ່ງ fcoe ບໍ່ມີຢູ່."

#: pyanaconda/kickstart.py:752
#, python-format
msgid "%s is missing. Cannot setup firewall."
msgstr "ບໍ່ພົບ %s. ບໍ່ສາມາດຕັ້ງຄ່າໄຟວໍໄດ້."

#: pyanaconda/kickstart.py:807 pyanaconda/kickstart.py:818
#, python-format
msgid "Disk \"%s\" given in ignoredisk command does not exist."
msgstr "ດິສກ໌ \"%s\" ທີ່ລະບຸໃນຄຳສັ່ງ ignoredisk ບໍ່ມີຢູ່."

#: pyanaconda/kickstart.py:831
#, python-format
msgid ""
"Network interface \"%(nic)s\" required by iSCSI \"%(iscsiTarget)s\" target "
"is not up."
msgstr ""
"ອິນເຕີເຟສເຄືອຂ່າຍ \"%(nic)s\" ທີ່ iSCSI \"%(iscsiTarget)s\" ຕ້ອງການນັ້ນບໍ່ໄດ້ເປີດໃຊ້ງານ."

#: pyanaconda/kickstart.py:841
msgid ""
"iscsi --iface must be specified (binding used) either for all targets or for "
"none"
msgstr "ຕ້ອງລະບຸ iscsi --iface (ໃຊ້ການຜູກມັດ) ສຳລັບທຸກເປົ້າໝາຍ ຫຼື ບໍ່ລະບຸເລີຍ"

#: pyanaconda/kickstart.py:934
#, python-format
msgid ""
"No volume group exists with the name \"%s\".  Specify volume groups before "
"logical volumes."
msgstr "ບໍ່ມີກຸ່ມວໍລຸມຊື່ \"%s\". ໃຫ້ລະບຸກຸ່ມວໍລຸມກ່ອນວໍລຸມໂລຈິກ."

#: pyanaconda/kickstart.py:941
msgid "Cache PVs must belong to the same VG as the cached LV"
msgstr "PV ສຳລັບແຄຊຕ້ອງຢູ່ໃນ VG ດຽວກັນກັບ LV ທີ່ຖືກແຄຊ"

#: pyanaconda/kickstart.py:948
#, python-format
msgid ""
"No thin pool exists with the name \"%s\". Specify thin pools before thin "
"volumes."
msgstr "ບໍ່ມີ thin pool ຊື່ \"%s\". ໃຫ້ລະບຸ thin pool ກ່ອນ thin volume."

#: pyanaconda/kickstart.py:956
msgid "logvol --noformat must also use the --name= option."
msgstr "logvol --noformat ຕ້ອງໃຊ້ຕົວເລືອກ --name= ນຳ."

#: pyanaconda/kickstart.py:961 pyanaconda/kickstart.py:1031
#, python-format
msgid "Logical volume \"%s\" given in logvol command does not exist."
msgstr "ວໍລຸມໂລຈິກ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ logvol ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:972 pyanaconda/kickstart.py:981
#: pyanaconda/kickstart.py:1041 pyanaconda/kickstart.py:1385
#: pyanaconda/kickstart.py:1394 pyanaconda/kickstart.py:1477
#, python-format
msgid "Target size \"%(size)s\" for device \"%(device)s\" is invalid."
msgstr "ຂະໜາດເປົ້າໝາຍ \"%(size)s\" ສຳລັບອຸປະກອນ \"%(device)s\" ບໍ່ຖືກຕ້ອງ."

#: pyanaconda/kickstart.py:995
#, python-format
msgid ""
"Logical volume name \"%(logvol)s\" is already in use in volume group "
"\"%(volgroup)s\"."
msgstr "ຊື່ວໍລຸມໂລຈິກ \"%(logvol)s\" ຖືກນຳໃຊ້ແລ້ວໃນກຸ່ມວໍລຸມ \"%(volgroup)s\"."

#: pyanaconda/kickstart.py:1002
#, python-format
msgid ""
"No size given for logical volume \"%s\".  Use one of --useexisting, --size, "
"or --percent."
msgstr ""
"ບໍ່ໄດ້ລະບຸຂະໜາດສຳລັບ logical volume \"%s\". ກະລຸນາໃຊ້ --useexisting, --size, ຫຼື --"
"percent."

#: pyanaconda/kickstart.py:1005
#, python-format
msgid ""
"Logical volume size \"%(logvolSize)s\" must be larger than the volume group "
"extent size of \"%(extentSize)s\"."
msgstr ""
"ຂະໜາດວໍລຸມໂລຈິກ \"%(logvolSize)s\" ຕ້ອງໃຫຍ່ກວ່າຂະໜາດ extent ຂອງກຸ່ມວໍລຸມ \"%"
"(extentSize)s\"."

#: pyanaconda/kickstart.py:1009
msgid "Percentage must be between 0 and 100."
msgstr "ເປີເຊັນຕ້ອງຢູ່ລະຫວ່າງ 0 ຫາ 100."

#: pyanaconda/kickstart.py:1020 pyanaconda/kickstart.py:1413
#: pyanaconda/kickstart.py:1646
#, python-format
msgid "The \"%s\" file system type is not supported."
msgstr "ບໍ່ຮອງຮັບປະເພດລະບົບໄຟລ໌ \"%s\"."

#: pyanaconda/kickstart.py:1173
#, python-format
msgid "Unknown or invalid device '%s' specified"
msgstr "ລະບຸອຸປະກອນ '%s' ທີ່ບໍ່ຮູ້ຈັກ ຫຼື ບໍ່ຖືກຕ້ອງ"

#: pyanaconda/kickstart.py:1178
#, python-format
msgid ""
"Unknown or invalid format '%(format)s' specified for device '%(device)s'"
msgstr ""
"ລະບຸຮູບແບບ '%(format)s' ທີ່ບໍ່ຮູ້ຈັກ ຫຼື ບໍ່ຖືກຕ້ອງສຳລັບອຸປະກອນ '%(device)s'"

#: pyanaconda/kickstart.py:1185
#, python-format
msgid "No format on device '%s'"
msgstr "ບໍ່ມີການຟໍແມັດໃນອຸປະກອນ '%s'"

#: pyanaconda/kickstart.py:1223
msgid "nvdimm: nvdimm plugin not available."
msgstr "nvdimm: ປັກອິນ nvdimm ບໍ່ພ້ອມໃຊ້ງານ."

#: pyanaconda/kickstart.py:1229 pyanaconda/kickstart.py:1237
#, python-format
msgid "nvdimm: namespace %s not found."
msgstr "nvdimm: ບໍ່ພົບ namespace %s."

#: pyanaconda/kickstart.py:1248
#, python-format
msgid "Disk \"%s\" given in nvdimm command does not exist."
msgstr "ດິສກ໌ \"%s\" ທີ່ລະບຸໃນຄຳສັ່ງ nvdimm ບໍ່ມີຢູ່."

#: pyanaconda/kickstart.py:1256 pyanaconda/kickstart.py:1260
#, python-format
msgid "The %s kickstart command is not currently supported."
msgstr "ຄຳສັ່ງ kickstart %s ຍັງບໍ່ຮອງຮັບໃນເວລານີ້."

#: pyanaconda/kickstart.py:1285
#, python-format
msgid "No disk found for specified BIOS disk \"%s\"."
msgstr "ບໍ່ພົບດິດສຳລັບດິດ BIOS ທີ່ລະບຸ \"%s\"."

#: pyanaconda/kickstart.py:1320
#, python-format
msgid "RAID partition \"%s\" is defined multiple times."
msgstr "ພາທິຊັນ RAID \"%s\" ຖືກກຳນົດຫຼາຍຄັ້ງ."

#: pyanaconda/kickstart.py:1331 pyanaconda/kickstart.py:1568
#, python-format
msgid "PV partition \"%s\" is defined multiple times."
msgstr "ພາທິຊັນ PV \"%s\" ຖືກກຳນົດຫຼາຍຄັ້ງ."

#: pyanaconda/kickstart.py:1342 pyanaconda/kickstart.py:1578
#, python-format
msgid "Btrfs partition \"%s\" is defined multiple times."
msgstr "ພາທິຊັນ Btrfs \"%s\" ຖືກກຳນົດຫຼາຍຄັ້ງ."

#: pyanaconda/kickstart.py:1362
#, python-format
msgid "The size \"%s\" is invalid."
msgstr "ຂະໜາດ \"%s\" ບໍ່ຖືກຕ້ອງ."

#: pyanaconda/kickstart.py:1369
msgid "part --noformat must also use the --onpart option."
msgstr "part --noformat ຕ້ອງໃຊ້ຕົວເລືອກ --onpart ນຳ."

#: pyanaconda/kickstart.py:1374 pyanaconda/kickstart.py:1468
#, python-format
msgid "Partition \"%s\" given in part command does not exist."
msgstr "ພາທິຊັນ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ part ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:1428 pyanaconda/kickstart.py:1442
#, python-format
msgid "Disk \"%s\" given in part command does not exist."
msgstr "ດິດ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ part ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:1431
#, python-format
msgid "Cannot install to unpartitionable device \"%s\"."
msgstr "ບໍ່ສາມາດຕິດຕັ້ງລົງໃນອຸປະກອນທີ່ແບ່ງພາທິຊັນບໍ່ໄດ້ \"%s\"."

#: pyanaconda/kickstart.py:1438
#, python-format
msgid "Disk \"%s\" in part command is not partitioned."
msgstr "ດິດ \"%s\" ໃນຄຳສັ່ງ part ຍັງບໍ່ໄດ້ແບ່ງພາທິຊັນ."

#: pyanaconda/kickstart.py:1451
#, python-format
msgid "The maximum size \"%s\" is invalid."
msgstr "ຂະໜາດສູງສຸດ \"%s\" ບໍ່ຖືກຕ້ອງ."

#: pyanaconda/kickstart.py:1600
msgid "raid --noformat must also use the --device option."
msgstr "raid --noformat ຕ້ອງໃຊ້ຕົວເລືອກ --device ນຳ."

#: pyanaconda/kickstart.py:1605
#, python-format
msgid "RAID device  \"%s\" given in raid command does not exist."
msgstr "ອຸປະກອນ RAID \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ raid ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:1628
#, python-format
msgid ""
"RAID device \"%(device)s\" has a format of \"%(format)s\", but should have a "
"format of \"mdmember\"."
msgstr ""
"ອຸປະກອນ RAID \"%(device)s\" ມີຮູບແບບເປັນ \"%(format)s\", ແຕ່ຄວນຈະມີຮູບແບບເປັນ "
"\"mdmember\"."

#: pyanaconda/kickstart.py:1633
#, python-format
msgid "Tried to use undefined partition \"%s\" in RAID specification."
msgstr "ພະຍາຍາມໃຊ້ພາທິຊັນທີ່ບໍ່ໄດ້ກຳນົດ \"%s\" ໃນການລະບຸ RAID."

#: pyanaconda/kickstart.py:1667
#, python-format
msgid "RAID volume \"%s\" specified with --useexisting does not exist."
msgstr "ວໍລຸມ RAID \"%s\" ທີ່ລະບຸດ້ວຍ --useexisting ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:1676
#, python-format
msgid "The RAID volume name \"%s\" is already in use."
msgstr "ຊື່ວໍລຸມ RAID \"%s\" ຖືກນຳໃຊ້ແລ້ວ."

#: pyanaconda/kickstart.py:1965
#, python-format
msgid ""
"Physical volume \"%(device)s\" has a format of \"%(format)s\", but should "
"have a format of \"lvmpv\"."
msgstr ""
"ວໍລຸມທາງກາຍະພາບ \"%(device)s\" ມີຮູບແບບເປັນ \"%(format)s\", ແຕ່ຄວນຈະມີຮູບແບບເປັນ "
"\"lvmpv\"."

#: pyanaconda/kickstart.py:1970
#, python-format
msgid "Tried to use undefined partition \"%s\" in Volume Group specification"
msgstr "ພະຍາຍາມໃຊ້ພາທິຊັນທີ່ບໍ່ໄດ້ກຳນົດ \"%s\" ໃນການລະບຸ Volume Group"

#: pyanaconda/kickstart.py:1976
#, python-format
msgid ""
"Volume group \"%s\" defined without any physical volumes.  Either specify "
"physical volumes or use --useexisting."
msgstr ""
"ກຸ່ມວໍລຸມ \"%s\" ຖືກກຳນົດໂດຍບໍ່ມີວໍລຸມທາງກາຍະພາບ. ກະລຸນາລະບຸວໍລຸມທາງກາຍະພາບ ຫຼື ໃຊ້ --"
"useexisting."

#: pyanaconda/kickstart.py:1986
#, python-format
msgid ""
"Volume group given physical extent size of \"%(extentSize)s\", but must be "
"one of:\n"
"%(validExtentSizes)s."
msgstr ""
"ກຸ່ມວໍລຸມຖືກກຳນົດຂະໜາດ physical extent ເປັນ \"%(extentSize)s\", ແຕ່ຕ້ອງເປັນໜຶ່ງໃນ:\n"
"%(validExtentSizes)s."

#: pyanaconda/kickstart.py:1993
msgid ""
"volgroup --noformat and volgroup --useexisting must also use the --name= "
"option."
msgstr ""
"volgroup --noformat ແລະ volgroup --useexisting ຕ້ອງໃຊ້ຕົວເລືອກ --name= ນຳ."

#: pyanaconda/kickstart.py:1998
#, python-format
msgid "Volume group \"%s\" given in volgroup command does not exist."
msgstr "ກຸ່ມວໍລຸມ \"%s\" ທີ່ກຳນົດໃນຄຳສັ່ງ volgroup ບໍ່ມີຢູ່ຈິງ."

#: pyanaconda/kickstart.py:2001
#, python-format
msgid "The volume group name \"%s\" is already in use."
msgstr "ຊື່ກຸ່ມວໍລຸມ \"%s\" ຖືກນຳໃຊ້ແລ້ວ."

#: pyanaconda/kickstart.py:2124
msgid ""
"Incorrectly specified origin of the snapshot. Use format \"VolGroup/LV_name\""
msgstr ""
"ລະບຸແຫຼ່ງທີ່ມາຂອງ snapshot ບໍ່ຖືກຕ້ອງ. ກະລຸນາໃຊ້ຮູບແບບ \"VolGroup/LV_name\""

#: pyanaconda/kickstart.py:2135
#, python-format
msgid ""
"Snapshot: origin \"%(origin)s\" of snapshot \"%(name)s\" is not a valid thin "
"LV device."
msgstr ""
"ສະແນບຊັອດ: ຕົ້ນທາງ \"%(origin)s\" ຂອງສະແນບຊັອດ \"%(name)s\" ບໍ່ແມ່ນອຸປະກອນ thin LV ທີ່ຖື"
"ກຕ້ອງ."

#: pyanaconda/kickstart.py:2143
#, python-format
msgid "Snapshot %s already exists."
msgstr "ມີສະແນບຊັອດ %s ຢູ່ແລ້ວ."

#: pyanaconda/kickstart.py:2179
msgid ""
"The upgrade kickstart command is no longer supported. Upgrade functionality "
"is provided through fedup."
msgstr ""
"ຄຳສັ່ງ upgrade ໃນ kickstart ບໍ່ຮອງຮັບອີກຕໍ່ໄປ. ຟັງຊັນການອັບເກຣດແມ່ນໃຫ້ໃຊ້ຜ່ານ fedup ແທນ."

#: pyanaconda/network.py:110
msgid "Host name cannot be None or an empty string."
msgstr "ຊື່ໂຮສຕ໌ບໍ່ສາມາດເປັນຄ່າຫວ່າງ (None) ຫຼື ເປັນຊ່ອງຫວ່າງ."

#: pyanaconda/network.py:113
msgid "Host name must be 255 or fewer characters in length."
msgstr "ຊື່ໂຮສຕ໌ຕ້ອງມີຄວາມຍາວ 255 ຕົວອັກສອນ ຫຼື ໜ້ອຍກວ່າ."

#: pyanaconda/network.py:116
msgid ""
"Host names can only contain the characters 'a-z', 'A-Z', '0-9', '-', or '.', "
"parts between periods must contain something and cannot start or end with "
"'-'."
msgstr ""
"ຊື່ໂຮສຕ໌ສາມາດມີພຽງຕົວອັກສອນ 'a-z', 'A-Z', '0-9', '-', ຫຼື '.', ພາກສ່ວນລະຫວ່າງຈຸດຕ້ອງມີຂໍ້ຄວາ"
"ມ ແລະ ບໍ່ສາມາດເລີ່ມຕົ້ນ ຫຼື ລົງທ້າຍດ້ວຍ '-'."

