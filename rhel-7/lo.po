msgctxt "GUI|Main"
msgid "_No"
msgstr "ບໍໍ່(_N)"

#: pyanaconda/ui/gui/main.glade.h:4
msgctxt "GUI|Main"
msgid "_Yes"
msgstr "ແມ່ນ(_Y)"

#: pyanaconda/ui/gui/main.glade.h:5
msgid ""
"Are you sure you wish to quit the\n"
"installation process?"
msgstr ""
"ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການອອກຈາກ\n"
"ຂະບວນການຕິດຕັ້ງ?"

#: pyanaconda/ui/gui/main.glade.h:7
msgid "Quit"
msgstr "ອອກ"

#: pyanaconda/ui/gui/hubs/summary.glade.h:1
msgid "INSTALLATION SUMMARY"
msgstr "ສະຫຼຸບການຕິດຕັ້ງ"

#: pyanaconda/ui/gui/hubs/summary.glade.h:2
msgctxt "GUI|Summary"
msgid "_Quit"
msgstr "_ອອກ"

#: pyanaconda/ui/gui/hubs/summary.glade.h:3
msgctxt "GUI|Summary"
msgid "_Begin Installation"
msgstr "ເລີ່ມຕົ້ນກາ_ນຕິດຕັ້ງ"

#: pyanaconda/ui/gui/hubs/summary.glade.h:4
msgid "We won't touch your disks until you click 'Begin Installation'."
msgstr "ພວກເຮົາຈະບໍ່ແຕະຕ້ອງດິດຂອງທ່ານຈົນກວ່າທ່ານຈະຄລິກ 'ເລີ່ມຕົ້ນການຕິດຕັ້ງ'."

#: pyanaconda/ui/gui/hubs/progress.glade.h:1
