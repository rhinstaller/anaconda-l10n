#: pyanaconda/modules/storage/bootloader/base.py:652
#, python-format
msgid ""
"%(bootloader_stage2_description)s cannot be on an iSCSI disk which is not "
"configured in iBFT."
msgstr "%(bootloader_stage2_description)s ບໍ່ສາມາດຢູ່ໃນດິສກ໌ iSCSI ທີ່ບໍ່ໄດ້ຕັ້ງຄ່າໃນ iBFT."

#: pyanaconda/modules/storage/bootloader/base.py:659
#, python-format
msgid "%(desc)s cannot be of type %(type)s"
msgstr "%(desc)s ບໍ່ສາມາດເປັນປະເພດ %(type)s"

#: pyanaconda/modules/storage/bootloader/base.py:380
#, python-format
msgid "%(desc)s cannot be of type %(type)s."
msgstr "%(desc)s ບໍ່ສາມາດເປັນປະເພດ %(type)s ໄດ້."

#: pyanaconda/modules/storage/bootloader/base.py:398
#, python-format
msgid "%(desc)s must be between %(min)d and %(max)d MB in size"
msgstr "%(desc)s ຕ້ອງມີຂະໜາດລະຫວ່າງ %(min)d ຫາ %(max)d MB"

#: pyanaconda/modules/storage/bootloader/base.py:386
#, python-format
msgid "%(desc)s must be mounted on one of %(mountpoints)s."
msgstr "%(desc)s ຕ້ອງເຊື່ອມຕໍ່ກັບໜຶ່ງໃນ %(mountpoints)s."

#: pyanaconda/modules/storage/bootloader/base.py:431
#, python-format
msgid "%(desc)s must be within the first %(max_end)s of the disk."
msgstr "%(desc)s ຕ້ອງຢູ່ພາຍໃນ %(max_end)s ທຳອິດຂອງດິສກ໌."

#: pyanaconda/modules/storage/bootloader/base.py:413
#, python-format
msgid "%(desc)s must not be larger than %(max)dMB."
msgstr "%(desc)s ຕ້ອງບໍ່ໃຫຍ່ກວ່າ %(max)dMB."

#: pyanaconda/modules/storage/bootloader/base.py:404
#, python-format
msgid "%(desc)s must not be smaller than %(min)dMB."
msgstr "%(desc)s ຕ້ອງບໍ່ນ້ອຍກວ່າ %(min)dMB."

#: pyanaconda/modules/storage/bootloader/grub2.py:475
#, python-format
msgid ""
"%(deviceName)s may not have enough space for grub2 to embed core.img when "
"using the %(fsType)s file system on %(deviceType)s"
msgstr ""
"%(deviceName)s ອາດຈະບໍ່ມີພື້ນທີ່ພຽງພໍສຳລັບ grub2 ໃນການຝັງ core.img ເມື່ອໃຊ້ລະບົບໄຟລ໌ "
"%(fsType)s ໃນ %(deviceType)s"

